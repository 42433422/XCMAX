# Copy to repo root as `.env.fhd-docker` and adjust. Used by docker/docker-compose.fhd-full.yml
SECRET_KEY=change-me-to-openssl-rand-hex-32
DATABASE_URL=postgresql+psycopg://xcagi:YOUR_PASSWORD@host.docker.internal:5433/xcagi
VECTOR_DB_URL=postgresql+psycopg://xcagi:YOUR_PASSWORD@host.docker.internal:5433/xcagi
CORS_ALLOW_ORIGINS=https://xiu-ci.com,http://127.0.0.1:5001,http://localhost:5001,http://127.0.0.1:5173,http://localhost:5173
# CORS_ALLOW_ORIGIN_REGEX=^http://10\.86\.\d{1,3}\.\d{1,3}(:\d+)?$
XCAGI_DEBUG=0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe_After_First_Login
# ADMIN_DISPLAY_NAME=Administrator

# Optional: skip migrations on start (debug only)
# FHD_SKIP_ALEMBIC=1

# Optional: bind host mods into container (absolute path on host)
# FHD_MODS_MOUNT=/root/fhd-sandbox-runtime/mods

# NeuroBus NN 路由策略：shadow=影子模式（记录 NN 决策但不实际路由）
# 切灰度：XCAGI_ROUTING_POLICY_ENABLED=1 + XCAGI_ROUTING_POLICY_CANARY_RATIO=0.1
XCAGI_ROUTING_POLICY_ENABLED=shadow
XCAGI_ROUTING_POLICY_CANARY_RATIO=0.0
