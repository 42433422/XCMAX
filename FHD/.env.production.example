# =============================================================================
# Production Docker Compose — copy to .env beside docker-compose.yml
# =============================================================================
# Generate secrets:
#   openssl rand -hex 32          # SECRET_KEY
#   openssl rand -base64 24       # POSTGRES_PASSWORD, REDIS_PASSWORD
#   openssl rand -base64 16       # GF_SECURITY_ADMIN_PASSWORD
#
# docker compose config  # must succeed before docker compose up
# =============================================================================

SECRET_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Optional overrides (defaults built from POSTGRES_PASSWORD / REDIS_PASSWORD)
# DATABASE_URL=postgresql+psycopg://xcagi:${POSTGRES_PASSWORD}@postgres:5432/xcagi
# CACHE_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Monitoring stack (docker-compose.monitoring.yml)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
