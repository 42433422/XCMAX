{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "../frontend",
    "paths": {
      "@/*": ["./src/*"],
      "@amin/*": ["../AMIN/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "*.ts",
    "**/*.ts",
    "**/*.vue",
    "../frontend/src/env.d.ts"
  ]
}
