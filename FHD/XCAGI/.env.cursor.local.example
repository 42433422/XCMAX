# Cursor 认证（vibe-coding-maintainer · skill-cursor-sdk-delegate）
# 复制：cp FHD/XCAGI/.env.cursor.local.example FHD/XCAGI/.env.cursor.local
# 或运行：bash FHD/scripts/dev/setup_cursor_auth.sh

# 推荐：cli（本机 cursor agent login，无需 API Key）
CURSOR_AUTH_MODE=cli
CURSOR_AGENT_MODEL=composer-2.5

# 可选：sdk 模式（Dashboard → Integrations → User API Keys）
# CURSOR_AUTH_MODE=sdk
# CURSOR_API_KEY=crsr_your_key_here
