# Template only — do NOT commit real secrets.
# Create in cluster: kubectl create secret generic xcagi-secrets \
#   --from-literal=deepseek_api_key='...' \
#   --from-literal=database_url='postgresql://...'
# Or use Sealed Secrets / External Secrets Operator.
apiVersion: v1
kind: Secret
metadata:
  name: xcagi-secrets
type: Opaque
stringData:
  deepseek_api_key: "REPLACE_ME"
  database_url: "REPLACE_ME"
