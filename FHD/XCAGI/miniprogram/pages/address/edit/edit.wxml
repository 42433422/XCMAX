<view class="page"><form bindsubmit="submitForm">
  <view class="card form-item"><label>联系人</label><input name="contact_name" value="{{form.contact_name}}" placeholder="请输入姓名"/></view>
  <view class="card form-item"><label>手机号</label><input name="contact_phone" value="{{form.contact_phone}}" type="number" placeholder="请输入手机号"/></view>
  <view class="card form-item"><label>省份</label><input name="province" value="{{form.province}}" placeholder="请输入省份"/></view>
  <view class="card form-item"><label>城市</label><input name="city" value="{{form.city}}" placeholder="请输入城市"/></view>
  <view class="card form-item"><label>区县</label><input name="district" value="{{form.district}}" placeholder="请输入区县"/></view>
  <view class="card form-item"><label>详细地址</label><textarea name="detail_address" value="{{form.detail_address}}" placeholder="请输入详细地址"></textarea></view>
  <view class="card form-item switch-row"><label>设为默认</label><switch checked="{{form.is_default}}" bindchange="onSwitch"/></view>
  <button form-type="submit" class="submit-btn">保存</button>
</form></view>
