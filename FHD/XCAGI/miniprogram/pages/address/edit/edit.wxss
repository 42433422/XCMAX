.form-item{display:flex;align-items:center;margin-bottom:4rpx;padding:20rpx 0;border-bottom:1rpx solid #f5f5f5;}form-item label{width:140rpx;font-size:28rpx;color:#666;flex-shrink:0;}form-item input,form-item textarea{flex:1;font-size:28rpx;text-align:right;}.switch-row{justify-content:space-between;}switch{transform:scale(0.8);}.submit-btn{margin:40rpx 0;background:#1890ff;color:#fff;border-radius:44rpx;}