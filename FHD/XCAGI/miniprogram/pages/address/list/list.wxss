.addr-card{position:relative;}.addr-header{display:flex;align-items:center;gap:16rpx;margin-bottom:8rpx;font-size:28rpx;}.addr-header text:first-child{font-weight:bold;}.tag{background:#1890ff;color:#fff;font-size:20rpx;padding:2rpx 10rpx;border-radius:4rpx;margin-left:auto;}.addr-text{font-size:26rpx;color:#666;line-height:40rpx;display:block;}.addr-actions{display:flex;justify-content:flex-end;gap:24rpx;padding-top:16rpx;border-top:1rpx solid #f5f5f5;font-size:24rpx;color:#1890ff;}.add-btn{margin:30rpx;background:#1890ff;color:#fff;border-radius:44rpx;}