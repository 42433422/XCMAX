<view class="page">
  <view class="addr-item card" wx:for="{{addresses}}" wx:key="id" bindtap="selectAddr" data-id="{{item.id}}">
    <view class="addr-info"><text class="name">{{item.contact_name}}</text><text>{{item.contact_phone}}</text><text class="tag" wx:if="{{item.is_default}}">默认</text></view>
    <text class="addr-text">{{item.full_address}}</text>
  </view>
  <view class="empty" wx:if="{{!addresses.length}}"><text>暂无地址</text></view>
  <button bindtap="addNew">+ 新增地址</button>
</view>
