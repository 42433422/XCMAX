<view class="page cart-page">
  <view class="cart-empty" wx:if="{{!loading && !items.length}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-title">购物车是空的</text>
    <text class="empty-desc">去挑选心仪的商品吧</text>
    <button class="btn btn-primary btn-lg" bindtap="goShopping">去逛逛</button>
  </view>

  <view wx:else>
    <!-- 列表 -->
    <scroll-view scroll-y style="height: calc(100vh - 160rpx);" enhanced show-scrollbar="{{false}}">
      <view class="list">
        <view class="item card" wx:for="{{items}}" wx:key="cart_id">
          <view class="check" bindtap="toggleSelect" data-id="{{item.product_id}}">
            <view class="checkbox {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view>
          </view>

          <image src="/assets/product-placeholder.png" mode="aspectFill" class="item-img"
                 bindtap="goDetail" data-id="{{item.product_id}}" lazy-load />

          <view class="item-body">
            <text class="item-name text-ellipsis">{{item.product_name}}</text>
            <text class="item-sku text-hint">{{item.model_number}}</text>
            <view class="item-bot">
              <text class="price price-sm">¥{{item.unit_price}}</text>
              <view class="stepper">
                <text class="s-btn {{item.quantity <= 1 ? 'dis' : ''}}" catchtap="decreaseQty" data-id="{{item.product_id}}">−</text>
                <text class="s-val">{{item.quantity}}</text>
                <text class="s-btn" catchtap="increaseQty" data-id="{{item.product_id}}">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view style="height: 140rpx;"></view>
    </scroll-view>

    <!-- 结算栏 -->
    <view class="checkout-bar safe-bottom">
      <view class="ck-left" bindtap="toggleSelectAll">
        <view class="checkbox {{allSelected ? 'checked' : ''}}"><text wx:if="{{allSelected}}">✓</text></view>
        <text>全选</text>
      </view>
      <view class="ck-right">
        <text class="ck-label">合计</text>
        <text class="price price-lg">¥{{summary.total_amount}}</text>
        <button class="btn btn-danger btn-sm" disabled="{{!summary.selected_count}}" bindtap="goCheckout">结算({{summary.selected_count}})</button>
      </view>
    </view>
  </view>
</view>
