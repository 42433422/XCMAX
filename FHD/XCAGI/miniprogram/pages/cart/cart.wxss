.cart-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #333333; display: block; margin-bottom: 8rpx; }
.empty-desc { font-size: 26rpx; color: #999999; margin-bottom: 40rpx; }

.list { padding: 20rpx 28rpx; }

.item { display: flex; align-items: center; gap: 18rpx; padding: 28rpx !important; margin-bottom: 16rpx; }
.check { flex-shrink: 0; }
.checkbox {
  width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #dcdcdc;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #ffffff; transition: all 0.15s;
}
.checkbox.checked { background: #0052d9; border-color: #0052d9; }
.item-img { width: 150rpx; height: 150rpx; border-radius: 10rpx; flex-shrink: 0; background: #fafafa; }
.item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; height: 150rpx; }
.item-name { font-size: 27rpx; font-weight: 500; }
.item-sku { font-size: 23rpx; margin-top: 4rpx; }
.item-bot { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }

/* 步进器 */
.stepper { display: flex; align-items: center; border: 2rpx solid #eeeeee; border-radius: 6rpx; overflow: hidden; }
.s-btn { width: 52rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; color: #666666; background: #fafafa; }
.s-btn:active { background: #f0f0f0; }
.s-btn.dis { color: #cccccc; pointer-events: none; }
.s-val { min-width: 56rpx; height: 48rpx; line-height: 48rpx; text-align: center; font-size: 27rpx; font-weight: 600; border-left: 2rpx solid #eeeeee; border-right: 2rpx solid #eeeeee; }

/* 结算栏 */
.checkout-bar { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; }
.ck-left { display: flex; align-items: center; gap: 12rpx; font-size: 27rpx; color: #666666; }
.ck-right { display: flex; align-items: center; gap: 14rpx; }
.ck-label { font-size: 26rpx; color: #666666; }
