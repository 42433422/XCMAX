<view class="page cat-page">
  <view class="cat-layout">
    <scroll-view scroll-y class="cat-left" enhanced show-scrollbar="{{false}}">
      <text class="ci {{currentCat === -1 ? 'on' : ''}}" bindtap="selectCat" data-id="-1">全部分类</text>
      <text class="ci {{currentCat === index ? 'on' : ''}}" wx:for="{{categories}}" wx:key="*this"
            bindtap="selectCat" data-id="{{index}}">{{item}}</text>
    </scroll-view>
    <scroll-view scroll-y class="cat-right" style="height: 100vh;" enhanced show-scrollbar="{{false}}"
                  bindscrolltolower="loadMoreProducts">
      <view class="rg-head" wx:if="{{currentCat >= 0 && categories[currentCat]}}"><text>{{categories[currentCat]}}</text></view>

      <view class="pg" wx:if="{{products.length}}">
        <view class="pi card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image src="/assets/product-placeholder.png" mode="aspectFill" class="pi-img" />
          <text class="pi-name text-ellipsis">{{item.name}}</text>
          <view class="pi-bot"><text class="price price-sm">¥{{item.price}}</text><text class="pi-unit">/{{item.unit}}</text></view>
        </view>
      </view>

      <view class="empty" wx:if="{{!loading && !products.length}}"><text>暂无商品</text></view>
    </scroll-view>
  </view>
</view>
