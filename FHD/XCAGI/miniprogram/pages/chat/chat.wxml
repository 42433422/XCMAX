<view class="page chat-page">
  <view class="chat-header">
    <text class="chat-title">AI 客服</text>
    <text class="chat-dot">●</text>
  </view>

  <scroll-view scroll-y class="chat-body" enhanced show-scrollbar="{{false}}" scroll-into-view="{{scrollTo}}">
    <!-- 欢迎 -->
    <view class="welcome" wx:if="{{!messages.length}}">
      <text class="w-text">您好，有什么可以帮您？</text>
      <view class="w-tags">
        <text class="tag tag-outline" wx:for="{{intents}}" wx:key="key" bindtap="sendIntent" data-text="{{item.example}}">{{item.label}}</text>
      </view>
    </view>

    <!-- 消息 -->
    <view class="msg" wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}">
      <view class="bubble {{item.role}}"><text>{{item.content}}</text></view>
      <text class="mtime text-hint">{{item.time || ''}}</text>
    </view>

    <!-- 打字中 -->
    <view class="typing" wx:if="{{isTyping}}">
      <view class="bubble ai"><text class="dot-a">● ● ●</text></view>
    </view>

    <view style="height: 40rpx;" class="safe-bottom"></view>
  </scroll-view>

  <!-- 意图 -->
  <scroll-view scroll-x class="intents" enhanced show-scrollbar="{{false}}">
    <text class="chip" wx:for="{{intents}}" wx:key="key" bindtap="sendIntent" data-text="{{item.example}}">{{item.label}}</text>
  </scroll-view>

  <!-- 输入 -->
  <view class="input-bar safe-bottom">
    <input placeholder="输入您的问题..." value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
    <button class="btn btn-primary btn-sm" bindtap="sendMessage" disabled="{{!inputText.trim() || isTyping}}">发送</button>
  </view>
</view>
