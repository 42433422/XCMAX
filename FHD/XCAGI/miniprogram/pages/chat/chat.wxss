.chat-header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; background: #ffffff; border-bottom: 1rpx solid #eeeeee; }
.chat-title { font-size: 32rpx; font-weight: 700; color: #333333; }
.chat-dot { font-size: 22rpx; color: #00a870; }

.chat-body { flex: 1; padding: 28rpx; overflow: hidden; }

.welcome { text-align: center; padding: 60rpx 0 40rpx; }
.w-text { font-size: 28rpx; color: #666666; display: block; margin-bottom: 28rpx; }
.w-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 14rpx; }

.msg { margin-bottom: 28rpx; }
.bubble {
  display: inline-block; max-width: 75%; padding: 22rpx 28rpx;
  border-radius: 12rpx; font-size: 27rpx; line-height: 42rpx; word-break: break-all;
}
.bubble.user { background: #0052d9; color: #ffffff; border-radius: 16rpx 4rpx 12rpx 12rpx; float: right; }
.bubble.ai { background: #f5f5f5; color: #333333; border-radius: 4rpx 16rpx 12rpx 12rpx; float: left; clear: both; }
.mtime { font-size: 20rpx; display: block; margin-top: 8rpx; text-align: right; }
.msg .user .mtime { text-align: left; }

.typing { clear: both; overflow: hidden; }
.dot-a { letter-spacing: 6rpx; opacity: 0.5; }

.intents { background: #ffffff; padding: 14rpx 28rpx; white-space: nowrap; border-top: 1rpx solid #eeeeee; }
.chip { display: inline-block; padding: 12rpx 26rpx; background: #f5f5f5; border-radius: 20rpx; font-size: 25rpx; color: #666666; margin-right: 14rpx; }
.chip:active { background: #0052d9; color: #ffffff; }

.input-bar { display: flex; gap: 14rpx; align-items: center; padding: 18rpx 28rpx; background: #ffffff; border-top: 1rpx solid #eeeeee; }
.input-bar input { flex: 1; background: #f5f5f5; border-radius: 8rpx; padding: 20rpx 24rpx; font-size: 27rpx; box-sizing: border-box; }
