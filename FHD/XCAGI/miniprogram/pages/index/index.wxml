<view class="page">
  <view class="search-bar">
    <view class="search-box" bindtap="goSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品</text>
    </view>
    <view class="msg-btn" bindtap="goMessage">
      <text>📩</text>
      <view class="badge-dot" wx:if="{{unreadCount > 0}}"></view>
    </view>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" style="height: calc(100vh - 88rpx);">
    <!-- Banner -->
    <swiper class="banner" indicator-dots indicator-color="rgba(0,0,0,0.12)" indicator-active-color="#0052d9" autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.bg}}">
          <view class="banner-body">
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-desc">{{item.desc}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <!-- 快捷入口 -->
    <view class="grid card">
      <view class="grid-item" wx:for="{{quickEntries}}" wx:key="id"
            bindtap="onEntryTap" data-type="{{item.type}}" data-id="{{item.id}}">
        <text class="grid-icon">{{item.icon}}</text>
        <text class="grid-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="section-header">
      <text class="section-title">推荐商品</text>
      <text class="section-more" bindtap="goCategory">查看全部 ›</text>
    </view>

    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id"
            hover-class="card-active"
            bindtap="goDetail" data-id="{{item.id}}">
        <view class="p-img-wrap">
          <image src="/assets/product-placeholder.png" mode="aspectFill" class="p-img" lazy-load />
          <view class="p-tag tag-danger" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
        <view class="p-info">
          <text class="p-name text-ellipsis">{{item.name}}</text>
          <view class="p-price-row">
            <text class="price price-md">¥{{item.price}}</text>
            <text class="p-unit">/{{item.unit}}</text>
          </view>
        </view>
        <view class="p-actions">
          <view class="p-fav" catchtap="toggleFavorite" data-id="{{item.id}}">{{item.isFav ? '★' : '☆'}}</view>
          <view class="p-add" catchtap="quickAddCart" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>

    <view class="loading" wx:if="{{loading}}">加载中...</view>
    <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">— 没有更多了 —</view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
