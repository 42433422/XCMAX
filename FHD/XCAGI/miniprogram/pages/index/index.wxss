/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 28rpx;
  background: #ffffff;
}
.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 18rpx 24rpx;
}
.search-icon { font-size: 28rpx; opacity: 0.45; }
.search-placeholder { font-size: 26rpx; color: #bbbbbb; }
.msg-btn { position: relative; width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }

/* Banner - 纯净风格 */
.banner { margin: 0 28rpx; border-radius: 12rpx; overflow: hidden; height: 280rpx; }
.banner-item {
  display: flex; align-items: center; justify-content: center;
  height: 100%; padding: 40rpx; box-sizing: border-box;
}
.banner-body { text-align: center; }
.banner-title {
  font-size: 38rpx; font-weight: 700; color: #ffffff;
  display: block; margin-bottom: 10rpx;
}
.banner-desc { font-size: 25rpx; color: rgba(255,255,255,0.85); }

/* 快捷入口网格 */
.grid { display: grid; grid-template-columns: repeat(4, 1fr); padding: 32rpx 24rpx !important; margin: 20rpx 28rpx !important; }
.grid-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 4rpx 20rpx;
}
.grid-icon { font-size: 44rpx; line-height: 1; margin-bottom: 10rpx; }
.grid-label { font-size: 23rpx; color: #666666; }

/* 区块标题 */
.section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  padding: 10rpx 28rpx 22rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #333333; }
.section-more { font-size: 24rpx; color: #999999; }

/* 商品卡片 - 双列瀑布流 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 28rpx;
}
.product-card {
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  transition: transform 0.15s;
}
.card-active { transform: scale(0.97); }

.p-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #fafafa;
  overflow: hidden;
}
.p-img { width: 100%; height: 100%; object-fit: cover; }
.p-tag { position: absolute; top: 12rpx; left: 12rpx; }

.p-info { padding: 18rpx 20rpx 14rpx; }
.p-name {
  font-size: 27rpx; font-weight: 500; color: #333333;
  line-height: 38rpx; height: 76rpx; overflow: hidden;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.p-price-row { display: flex; align-items: baseline; margin-top: 12rpx; }
.p-unit { font-size: 21rpx; color: #999999; margin-left: 4rpx; }

.p-actions {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10rpx 20rpx 16rpx; border-top: 1rpx solid #f5f5f5;
}
.p-fav { font-size: 34rpx; color: #cccccc; line-height: 1; }
.p-add {
  width: 48rpx; height: 48rpx; background: #0052d9; color: #fff;
  border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 30rpx; font-weight: 300;
}

.loading { text-align: center; padding: 36rpx 0; font-size: 24rpx; color: #bbbbbb; }
.no-more { text-align: center; padding: 30rpx 0; font-size: 23rpx; color: #cccccc; }
