.msg-item{position:relative;}.msg-header{display:flex;align-items:center;gap:12rpx;margin-bottom:10rpx;}.dot{width:12rpx;height:12rpx;border-radius:50%;background:#ff4d4f;flex-shrink:0;}.type-tag{font-size:20rpx;padding:2rpx 12rpx;border-radius:4rpx;background:#e6f7ff;color:#1890ff;}.type-tag.order{background:#fff7e6;color:#fa8c16;}.type-tag.system{background:#f5f5f5;color:#999;}.time{margin-left:auto;font-size:22rpx;color:#999;flex-shrink:0;}.title{display:block;font-size:30rpx;font-weight:bold;margin-bottom:6rpx;}.content{font-size:26rpx;color:#666;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}