<view class="page confirm-page">
  <scroll-view scroll-y class="confirm-scroll" style="height: calc(100vh - 140rpx);">
    <!-- 收货地址 -->
    <view class="addr-section card-flat" bindtap="selectAddress" wx:if="{{address}}">
      <view class="addr-top">
        <view class="addr-icon-wrap">
          <text>📍</text>
        </view>
        <view class="addr-info">
          <view class="addr-name-row">
            <text class="addr-name">{{address.contact_name}}</text>
            <text class="addr-phone">{{address.contact_phone}}</text>
            <text class="tag tag-primary" wx:if="{{address.is_default}}">默认</text>
          </view>
          <text class="addr-text">{{address.full_address}}</text>
        </view>
        <text class="addr-arrow">›</text>
      </view>
    </view>

    <view class="addr-empty card-flat" bindtap="selectAddress" wx:else>
      <view class="empty-addr-content">
        <text class="empty-addr-icon">📍</text>
        <text>选择收货地址</text>
        <text class="addr-arrow">›</text>
      </view>
    </view>

    <!-- 商品清单 -->
    <view class="section card-flat">
      <view class="section-header"><view class="section-title">商品清单</view><text class="item-count">{{items.length}}件商品</text></view>
      <view class="confirm-item" wx:for="{{items}}" wx:key="product_id">
        <image src="/assets/product-placeholder.png" mode="aspectFill" class="ci-img" />
        <view class="ci-body">
          <text class="ci-name">{{item.product_name}}</text>
          <text class="ci-sku">{{item.product_sku}}</text>
          <view class="ci-bottom">
            <text class="ci-price">¥{{item.unit_price}}<text class="ci-qty"> × {{item.quantity}}</text></text>
            <text class="ci-subtotal">¥{{item.subtotal}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="remark-section card-flat">
      <input placeholder="选填：订单备注信息" value="{{remark}}" bindinput="onRemarkInput" />
    </view>

    <!-- 价格明细 -->
    <view class="summary-section card-flat">
      <view class="s-row"><label>商品金额</label><value>¥{{summary.productAmount}}</value></view>
      <view class="s-row"><label>运费</label><value>¥{{summary.freight}}</value></view>
      <view class="s-divider"></view>
      <view class="s-row total"><label>实付金额</label><value>¥{{summary.totalAmount}}</value></view>
    </view>

    <view class="confirm-spacer"></view>
  </scroll-view>

  <!-- 底部提交栏 -->
  <view class="submit-bar safe-area-bottom">
    <view class="submit-total">
      <text>实付:</text>
      <text class="submit-price">¥{{summary.totalAmount}}</text>
    </view>
    <button class="btn-submit" bindtap="submitOrder">提交订单</button>
  </view>
</view>
