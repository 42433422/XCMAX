.confirm-page { display: flex; flex-direction: column; height: 100vh; background: var(--bg-page); }

.addr-section { margin: 20rpx 24rpx 16rpx; overflow: hidden; border-left: 6rpx solid var(--primary-color); }
.addr-top { display: flex; align-items: flex-start; gap: 14rpx; padding-right: 8rpx; }
.addr-icon-wrap { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; font-size: 28rpx; flex-shrink: 0; }
.addr-info { flex: 1; min-width: 0; }
.addr-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.addr-name { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }
.addr-phone { font-size: 26rpx; color: var(--text-secondary); }
.addr-text { font-size: 26rpx; color: var(--text-hint); line-height: 40rpx; display: block; }
.addr-arrow { font-size: 32rpx; color: var(--text-disabled); line-height: 1; align-self: center; flex-shrink: 0; }

.addr-empty { margin: 20rpx 24rpx 16rpx; text-align: center; padding: 24rpx; }
.empty-addr-content { display: flex; align-items: center; justify-content: center; gap: 10rpx; font-size: 29rpx; color: var(--primary-color); font-weight: 500; }
.empty-addr-icon { font-size: 34rpx; }

/* 商品清单 */
.section { margin: 0 24rpx 16rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.item-count { font-size: 24rpx; color: var(--text-hint); }

.confirm-item { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border-light); }
.confirm-item:last-child { border-bottom: none; }
.ci-img { width: 130rpx; height: 130rpx; border-radius: var(--radius-md); flex-shrink: 0; }
.ci-body { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; height: 130rpx; }
.ci-name { font-size: 27rpx; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ci-sku { font-size: 22rpx; color: var(--text-hint); margin-top: 4rpx; }
.ci-bottom { display: flex; justify-content: space-between; align-items: baseline; margin-top: auto; }
.ci-price { font-size: 26rpx; color: var(--text-hint); }
.ci-qty { font-size: 22rpx; margin-left: 4rpx; }
.ci-subtotal { font-size: 30rpx; color: var(--danger-color); font-weight: 800; }

/* 备注 */
.remark-section { margin: 0 24rpx 16rpx; }
.remark-section input { width: 100%; background: #fafafa; border: none; border-radius: var(--radius-md); padding: 22rpx 28rpx; font-size: 28rpx; box-sizing: border-box; }

/* 价格 */
.summary-section { margin: 0 24rpx 16rpx; }
.s-row { display: flex; justify-content: space-between; padding: 14rpx 0; font-size: 27rpx; color: var(--text-secondary); }
.s-row label { color: var(--text-secondary); }
.s-row value { color: var(--text-primary); font-weight: 500; }
.s-row.total { font-size: 30rpx; font-weight: 700; padding-top: 18rpx; }
.s-row.total label { color: var(--text-primary); }
.s-row.total value { color: var(--danger-color); font-size: 38rpx; font-weight: 900; }
.s-divider { height: 1rpx; background: var(--border-light); margin: 8rpx 0; }

.confirm-spacer { height: 140rpx; }

/* 提交栏 */
.submit-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; display: flex; align-items: center; justify-content: flex-end;
  gap: 24rpx; padding: 16rpx 28rpx; box-shadow: 0 -6rpx 30rpx rgba(0,0,0,0.08); z-index: 999;
}
.submit-total { display: flex; align-items: baseline; gap: 6rpx; }
.submit-total text:first-child { font-size: 26rpx; color: var(--text-secondary); }
.submit-price { font-size: 40rpx; color: var(--danger-color); font-weight: 900; }
.btn-submit {
  background: linear-gradient(135deg, #1890ff, #096dd9); color: #fff;
  border-radius: var(--radius-xl); font-size: 30rpx; font-weight: 700;
  padding: 24rpx 56rpx; line-height: 1; border: none !important; margin: 0 !important;
  box-shadow: 0 8rpx 24rpx rgba(24,144,255,0.35);
}
.btn-submit::after { border: none; }
.btn-submit:active { transform: scale(0.97); opacity: 0.9; }
