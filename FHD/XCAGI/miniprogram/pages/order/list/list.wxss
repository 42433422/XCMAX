.tabs { display: flex; background: #ffffff; padding: 0 12rpx; border-bottom: 1rpx solid #eeeeee; position: sticky; top: 0; z-index: 100; }
.tab {
  flex: 1; text-align: center; padding: 26rpx 0;
  font-size: 27rpx; color: #666666; font-weight: 500;
  position: relative; transition: color 0.15s;
}
.tab.on { color: #0052d9; font-weight: 700; }
.tab.on::after {
  content: ''; position: absolute; bottom: 14rpx; left: 50%; transform: translateX(-50%);
  width: 32rpx; height: 4rpx; background: #0052d9; border-radius: 2rpx;
}

.order-list { padding: 20rpx 28rpx; }

.ocard { margin-bottom: 20rpx; overflow: hidden; }
.oc-head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 18rpx; border-bottom: 1rpx solid #f5f5f5; }
.oc-head text:first-child { font-size: 25rpx; color: #999999; }
.ostatus { font-size: 24rpx; font-weight: 600; }
.s-pending { color: #ed7b2f; }
.s-paid { color: #0052d9; }
.s-shipped { color: #00a870; }
.s-completed { color: #999999; }
.s-cancelled { color: #e34d59; }

.oc-body { display: flex; gap: 16rpx; padding: 22rpx 0; }
.o-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; flex-shrink: 0; background: #fafafa; }
.o-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; height: 120rpx; }
.o-name { font-size: 27rpx; font-weight: 500; }
.o-count { font-size: 23rpx; margin-top: 4rpx; }

.oc-foot { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.o-time { font-size: 23rpx; }
.o-btns { display: flex; gap: 10rpx; }
.o-btns button { margin: 0 !important; }
