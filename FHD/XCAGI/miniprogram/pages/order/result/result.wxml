<view class="page result-page">
  <view class="icon-area">
    <text class="icon success">✓</text>
    <text class="title">下单成功</text>
    <text class="sub">订单号: {{orderNo || '-'}}</text>
  </view>
  <view class="actions">
    <button bindtap="goOrder">查看订单</button>
    <button bindtap="goHome" type="primary">继续购物</button>
  </view>
</view>
