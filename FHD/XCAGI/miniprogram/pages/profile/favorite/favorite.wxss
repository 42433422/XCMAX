.fav-item{display:flex;align-items:center;position:relative;}.fav-item image{width:140rpx;height:140rpx;border-radius:8rpx;margin-right:20rpx;}.info{flex:1;display:flex;justify-content:space-between;align-items:center;}.info .name{font-size:28rpx;flex:1;margin-right:16rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}info text:last-child{color:#ff4d4f;font-weight:bold;font-size:30rpx;}.remove{position:absolute;right:16rpx;top:50%;transform:translateY(-50%);color:#ccc;font-size:32rpx;padding:10rpx;}