.form-row{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;}form-row label{font-size:28rpx;color:#333;}form-row picker text{color:#1890ff;font-size:28rpx;}textarea{width:100%;height:200rpx;font-size:28rpx;box-sizing:border-box;}.image-area{padding:16rpx 0;}.image-area text{font-size:26rpx;color:#666;display:block;margin-bottom:12rpx;}.img-list{display:flex;flex-wrap:wrap;gap:12rpx;}.img-list image{width:140rpx;height:140rpx;border-radius:8rpx;}.submit-btn{margin:30rpx 0;background:#1890ff;color:#fff;border-radius:44rpx;}