.profile-card{padding:24rpx;background:#fff;border-radius:12rpx;margin:20rpx;text-align:center;}.avatar{width:140rpx;height:140rpx;border-radius:50%;margin-bottom:20rpx;}.info-row{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f5f5f5;}info-row label{color:#666;font-size:28rpx;}info-row input{text-align:right;flex:1;font-size:28rpx;}.save-btn{margin:30rpx;background:#1890ff;color:#fff;border-radius:44rpx;}