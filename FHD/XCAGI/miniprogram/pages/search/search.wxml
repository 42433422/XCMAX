<view class="page search-page">
  <view class="s-header">
    <view class="s-box">
      <text>🔍</text>
      <input focus placeholder="搜索商品名称 / 型号" value="{{keyword}}" bindinput="onInput" bindconfirm="doSearch" confirm-type="search" />
      <text class="s-clear" wx:if="{{keyword}}" bindtap="clearInput">✕</text>
    </view>
    <text class="s-cancel" bindtap="goBack">取消</text>
  </view>

  <scroll-view scroll-y style="height: calc(100vh - 88rpx);" enhanced show-scrollbar="{{false}}">
    <!-- 历史 -->
    <view class="sec" wx:if="{{!hasSearched && history.length}}">
      <view class="sec-hd"><text>搜索历史</text><text class="sec-clr" bindtap="clearHistory">清空</text></view>
      <view class="tags">
        <text class="tag tag-outline" wx:for="{{history}}" wx:key="*this" bindtap="quickSearch" data-word="{{item}}">{{item}}</text>
      </view>
    </view>

    <!-- 热搜 -->
    <view class="sec" wx:if="{{!hasSearched}}">
      <text class="sec-title">热门搜索</text>
      <view class="tags">
        <text class="tag tag-outline hot" wx:for="{{hotWords}}" wx:key="word" bindtap="quickSearch" data-word="{{item.word}}">{{item.word}}</text>
      </view>
    </view>

    <!-- 结果 -->
    <view class="sec" wx:if="{{hasSearched}}">
      <text class="sec-sub">找到 {{products.length}} 个结果</text>
      <view class="grid">
        <view class="ri card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image src="/assets/product-placeholder.png" mode="aspectFill" class="ri-img" />
          <text class="ri-name text-ellipsis">{{item.name}}</text>
          <text class="price price-sm">¥{{item.price}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{!loading && !products.length}}"><text>没有找到相关商品</text></view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
