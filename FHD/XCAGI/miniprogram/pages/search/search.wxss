.s-header { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 28rpx; background: #ffffff; position: sticky; top: 0; z-index: 100; }
.s-box { flex: 1; display: flex; align-items: center; gap: 12rpx; background: #f5f5f5; border-radius: 8rpx; padding: 18rpx 24rpx; }
.s-box text:first-child { font-size: 28rpx; opacity: 0.45; }
.s-box input { flex: 1; font-size: 28rpx; }
.s-clear { width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center; background: #e0e0e0; border-radius: 50%; font-size: 22rpx; color: #666; }
.s-cancel { font-size: 28rpx; color: #0052d9; white-space: nowrap; }

.sec { padding: 24rpx 28rpx; }
.sec-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.sec-hd text:first-child { font-size: 29rpx; font-weight: 700; color: #333333; }
.sec-clr { font-size: 25rpx; color: #999999; }
.sec-title { font-size: 29rpx; font-weight: 700; color: #333333; display: block; margin-bottom: 18rpx; }
.sec-sub { font-size: 25rpx; color: #999999; display: block; margin-bottom: 20rpx; }

.tags { display: flex; flex-wrap: wrap; gap: 14rpx; }
.tags .tag-outline { cursor: pointer; }

.grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-top: 4rpx; }
.ri { overflow: hidden; padding-bottom: 18rpx; }
.ri-img { width: 100%; aspect-ratio: 1/1; background: #fafafa; border-radius: 8rpx; margin-bottom: 12rpx; }
.ri-name { font-size: 26rpx; font-weight: 500; line-height: 38rpx; height: 76rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.hot { font-weight: 600; color: #e34d59; }
