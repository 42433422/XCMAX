{
  "name": "xcagi-frontend",
  "version": "10.0.0",
  "description": "XCAGI 前端测试配置",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint static/js/"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "static/js/**/*.js",
      "!static/js/**/*.test.js"
    ]
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@babel/plugin-transform-modules-systemjs": "7.29.4",
    "js-yaml": "4.2.0",
    "brace-expansion": "5.0.6"
  }
}
