<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Electron V8 引擎需要 JIT 执行权限 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Electron 需要未签名可执行内存权限（V8 回退路径） -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- 允许 DYLD 环境变量（子进程加载与调试兼容） -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- 后端 FastAPI 子进程需要出站网络（更新检查、LLM API、OCR 等） -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- 本地 FastAPI 子进程监听端口（默认 17500） -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- 桌面语音输入需要访问麦克风（MediaRecorder / getUserMedia） -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- 读写用户数据目录（SQLite 数据库、日志、上传文件、Mod） -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
