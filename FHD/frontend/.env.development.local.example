# 复制为 .env.development.local（git 忽略），只保留一种模式，勿混用端口。
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 模式 A — 交付/桌面开发（推荐，与 start-desktop.command 一致）              │
# │   后端 :5000  前端 :5001  VITE_API_BASE → 5000                           │
# └─────────────────────────────────────────────────────────────────────────┘
VITE_XCAGI_PRODUCT_SKU=enterprise
VITE_DEV_PORT=5001
VITE_API_BASE=http://127.0.0.1:5000
VITE_PERSONNEL_MOD_ID=xcmax-personnel
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 模式 B — 并排第二套树（FHD-个人 等，与仓根 .env.example 一致）             │
# │   后端 :5100  前端 :5101  仓库根 FASTAPI_PORT=5100                        │
# └─────────────────────────────────────────────────────────────────────────┘
# VITE_XCAGI_PRODUCT_SKU=enterprise
# VITE_DEV_PORT=5101
# VITE_API_BASE=http://127.0.0.1:5100
#
# 勿将 VITE_API_BASE 设为 5003：旧文档笔误；start-desktop-sqlite 监听 5000，非 5003。
