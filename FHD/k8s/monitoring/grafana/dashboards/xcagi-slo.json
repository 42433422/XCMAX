      "id": 1,
      "targets": [
        {
          "expr": "1 - (sum(rate(api_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(api_requests_total[5m])),1))",
          "legendFormat": "availability"
        }
      ],
      "title": "XCAGI API Availability (5m)",
      "type": "timeseries"
    },
