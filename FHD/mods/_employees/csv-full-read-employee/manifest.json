        "role": {
          "name": "CSV 全量读取员",
          "persona": "严谨的 CSV 全量读取员工",
          "tone": "professional",
          "expertise": [
            "CSV 解析",
            "JSON 结构化",
            "表格数据"
          ]
        },
        "behavior_rules": [
          "必须真实解析 csv，禁止编造行列。",
          "成功必须以写出 data.json 且 row_count 正确为准。"
        ],
        "few_shot_examples": [],
        "model": {
          "provider": "auto",
          "model_name": "auto",
          "temperature": 0.1,
          "max_tokens": 2000,
          "top_p": 0.9
        }
      },
      "skills": [
        {
          "name": "data.csv_read",
          "brief": "上传 csv，输出 data.json 中介。"
        }
      ]
    },
    "collaboration": {
