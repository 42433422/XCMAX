  "artifact": "employee_pack",
  "scope": "global",
  "dependencies": {
    "xcagi": ">=1.0.0"
  },
  "employee": {
    "id": "csv-generate-employee",
    "label": "CSV 生成员",
    "capabilities": [
      "data.json_read",
      "data.csv_write"
    ]
  },
  "workflow_employees": [
    {
      "id": "csv-generate-employee",
      "label": "CSV 生成员",
      "panel_title": "CSV 生成员",
