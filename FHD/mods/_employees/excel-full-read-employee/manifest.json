        "few_shot_examples": [],
        "model": {
          "provider": "auto",
          "model_name": "auto",
          "temperature": 0.1,
          "max_tokens": 2000,
          "top_p": 0.9
        }
      },
      "skills": [
        {
          "name": "excel.full_read",
          "brief": "上传 xlsx，输出 workbook.json 中介。"
        }
      ]
