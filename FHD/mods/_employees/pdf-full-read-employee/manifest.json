{
  "id": "pdf-full-read-employee",
  "name": "PDF 全量读取员",
  "version": "1.0.0",
  "author": "XCAGI",
  "description": "制作 PDF 全量读取员工包",
  "artifact": "employee_pack",
  "scope": "global",
  "dependencies": {
    "xcagi": ">=1.0.0"
  },
  "employee": {
    "id": "pdf-full-read-employee",
    "label": "PDF 生成员",
    "capabilities": [
      "pdf.native_text",
      "pdf.image_extract",
      "vision.vlm"
    ]
  },
  "workflow_employees": [
    {
      "id": "pdf-full-read-employee",
      "label": "PDF 生成员",
      "panel_title": "PDF 生成员",
      "panel_summary": "上传 .pdf，只读原生文字；图片分类存储并 VLM 描述。",
      "capabilities": [
        "pdf.native_text",
        "pdf.image_extract",
        "vision.vlm"
      ],
      "api_base_path": "employees/pdf-full-read-employee",
      "entry_action": "run"
    }
  ],
  "backend": {
    "entry": "blueprints",
    "init": "mod_init"
  },
  "employee_config_v2": {
    "identity": {
      "id": "pdf-full-read-employee",
      "version": "1.0.0",
      "artifact": "employee_pack",
      "name": "PDF 生成员",
      "description": "制作 PDF 全量读取员工包"
    },
    "perception": {
      "type": "file_or_text",
      "accepted_extensions": [
        ".pdf"
      ]
    },
    "memory": {
      "type": "session"
    },
    "cognition": {
      "agent": {
        "system_prompt": "你是PDF 生成员。你负责读取 PDF 原生文字并导出分类图片目录；正文禁止 LLM 编造；图片须走 VLM 描述（ctx.call_llm vision）。",
        "role": {
          "name": "PDF 生成员",
          "persona": "严谨的 PDF 全量读取员工",
          "tone": "professional",
          "expertise": [
            "PDF 原生文字",
            "图片分类",
            "VLM 描述"
          ]
        },
        "behavior_rules": [
          "正文必须来自 PDF 原生文字层，禁止 LLM 编造。",
          "图片须写入 outputs/images/<category>/ 并尽量生成 VLM sidecar。",
          "成功必须以写出 document_full.txt 与 images_index.json 为准。"
        ],
        "few_shot_examples": [],
        "model": {
          "provider": "auto",
          "model_name": "auto",
          "temperature": 0.1,
          "max_tokens": 2000,
          "top_p": 0.9
        }
      },
      "skills": [
        {
          "name": "pdf.full_read",
          "brief": "上传 pdf，原生文字 + 图片分类目录 + VLM sidecar。"
        }
      ]
    },
    "collaboration": {
      "workflow": {
        "workflow_id": 0,
        "name": "PDF 生成员"
      }
    },
    "actions": {
      "handlers": [
        "direct_python"
      ],
      "direct_python": {
        "module": "pdf_full_read_employee",
        "action": "convert",
        "default_output_relpath": "outputs/document_full.txt",
        "default_template_relpath": "",
        "default_use_personnel_roster": false
      }
    }
  },
  "metadata": {
    "framework_version": "2.0.0",
    "created_by": "asset_pipeline"
  },
  "actions": {
    "handlers": [
      "direct_python"
    ],
    "direct_python": {
      "module": "pdf_full_read_employee",
      "action": "convert",
      "default_output_relpath": "outputs/document_full.txt",
      "default_template_relpath": "",
      "default_use_personnel_roster": false
    }
  }
}
