      }
    },
    "actions": {
      "handlers": [
        "direct_python"
      ],
      "direct_python": {
        "module": "ppt_full_read_employee",
        "action": "convert",
        "default_output_relpath": "outputs/presentation_full.json",
        "default_template_relpath": "",
        "default_use_personnel_roster": true
      }
    }
  },
  "metadata": {
    "framework_version": "2.0.0",
