{
  "id": "attendance-industry",
  "name": "考勤行业包",
  "version": "1.0.0",
  "author": "XCAGI",
  "description": "考勤行业通用包：排班、出勤统计与行业词汇；部门/人员菜单与 AI 员工见账号定制 Mod。",
  "primary": true,
  "legacy_mod_ids": ["taiyangniao-pro"],
  "dependencies": {
    "xcagi": ">=1.0.0"
  },
  "backend": {
    "entry": "blueprints",
    "init": "mod_init"
  },
  "frontend": {
    "routes": "frontend/routes",
    "pro_entry_path": "/attendance-industry",
    "menu": []
  },
  "onboarding": {
    "custom_line_hint": "考勤转换、排班菜单与定制 AI 员工",
    "custom_mod_ids": ["taiyangniao-pro"]
  },
  "hooks": {},
  "industry": {
    "id": "考勤",
