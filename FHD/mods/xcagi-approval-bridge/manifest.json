{
  "id": "xcagi-approval-bridge",
  "name": "审批中心门面 Mod",
  "version": "10.0.0",
  "author": "成都修茈科技有限公司",
  "description": "审批 API 门面 + 里程碑 K/O+ Mod 业务页（物理视图在 Mod 包；ORM/DB 仍在宿主）。",
  "dependencies": {
    "xcagi": ">=10.0.0"
  },
  "backend": {
    "entry": "blueprints",
    "init": "mod_init"
  },
  "frontend": {
    "routes": "frontend/routes",
    "menu": [
      {
        "id": "mod-approval-hub",
        "label": "审批中心",
        "icon": "fa-check-square-o",
        "path": "/mod/xcagi-approval-bridge/approval-hub/workspace"
      }
    ],
    "menu_overrides": [
      {
        "key": "approval-hub",
        "hidden": true
      }
    ]
  },
  "hooks": {},
  "comms": {
    "exports": []
  },
  "config": {
    "approval_facade": true,
    "approval_pages_via_mod": true,
    "views_physical": true,
    "physical_views": [
      "ApprovalHubView.vue",
      "ApprovalWorkspaceView.vue",
      "ApprovalFlowManagementView.vue",
      "ApprovalRulesView.vue"
    ],
    "legacy_host_prefixes": [
      "/api/approval"
    ],
    "legacy_host_page_paths": [
      "/approval-hub",
      "/approval-hub/workspace",
      "/approval-hub/flow-management",
      "/approval-hub/rules"
    ],
    "phase": "O+"
  }
}
