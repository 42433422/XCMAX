# ----- 沙盒进程 -----
# 由 sandbox_run.py 默认设为 1：标记本进程为「在线 Mod 沙盒」，CSRF 对 POST /api/mod-store/install 放行（服务端推送）。
# 完整 FHD 生产勿设为 1。
# XCAGI_SANDBOX_INSTANCE=1

SANDBOX_HOST=0.0.0.0
SANDBOX_PORT=5099
# 部署在 https://domain/sandbox/ 且 nginx strip 前缀时，注入 HTML 资源前缀（无尾斜杠）
# SANDBOX_URL_PREFIX=/sandbox

# 桌面模式数据目录（xcagi.db 在下一级 data/xcagi.db）
# SANDBOX_RUNTIME_ROOT=/path/to/sandbox-app/data/runtime

# Mod 目录（默认：<FHD 仓库根>/mods）
# SANDBOX_MODS_ROOT=

# 首次启动写入的默认账号
SANDBOX_ADMIN_USERNAME=sandbox
SANDBOX_ADMIN_PASSWORD=sandbox
SANDBOX_ADMIN_DISPLAY_NAME=沙盒管理员

# 重启清空 SQLite（危险）
# SANDBOX_RESET_ON_BOOT=1

# ----- 与主栈一致（按需） -----
LAN_GUARD_ENABLED=0
XCAGI_NEURO_INTENT=0
XCAGI_DEBUG=1
XCAGI_DISABLE_REDIS=1

# 远端 Catalog（mod-store 安装）
# XCAGI_CATALOG_BASE_URL=https://xiu-ci.com/v1
# XCAGI_CATALOG_TOKEN=
