{
  "name": "xcmax-sunbird-console",
  "private": true,
  "version": "10.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "cd ../frontend && node --require ./vite-polyfill.cjs ./node_modules/vite/bin/vite.js dev --config ./sunbirdConsole.vite.config.js",
    "build": "cd ../frontend && node --require ./vite-polyfill.cjs ./node_modules/vite/bin/vite.js build --config ./sunbirdConsole.vite.config.js",
    "preview": "cd ../frontend && node --require ./vite-polyfill.cjs ./node_modules/vite/bin/vite.js preview --config ./sunbirdConsole.vite.config.js"
  }
}
