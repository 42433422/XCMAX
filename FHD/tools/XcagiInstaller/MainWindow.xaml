<Window x:Class="XcagiInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XCAGI"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="500"
        Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="WindowDrag_OnMouseDown">
  <Border Background="{StaticResource WindowBg}"
          CornerRadius="12"
          BorderBrush="#E5E5EA"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.18" Color="#000000" />
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="52" />
        <RowDefinition Height="*" />
        <RowDefinition Height="64" />
      </Grid.RowDefinitions>

      <!-- 顶栏 -->
      <Grid Grid.Row="0" Background="{StaticResource SurfaceBg}" MouseLeftButtonDown="WindowDrag_OnMouseDown">
        <Border BorderBrush="{StaticResource Separator}" BorderThickness="0,0,0,1" />
        <StackPanel x:Name="StepDotsPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="{StaticResource DotActive}" Margin="4,0" />
          <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="{StaticResource DotInactive}" Margin="4,0" />
          <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="{StaticResource DotInactive}" Margin="4,0" />
          <Ellipse x:Name="Dot4" Width="6" Height="6" Fill="{StaticResource DotInactive}" Margin="4,0" />
          <Ellipse x:Name="Dot5" Width="6" Height="6" Fill="{StaticResource DotInactive}" Margin="4,0" />
        </StackPanel>
        <Button Style="{StaticResource CloseButtonStyle}"
                Content="✕"
                HorizontalAlignment="Right"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Click="Close_OnClick" />
      </Grid>

      <!-- 内容 -->
      <Grid Grid.Row="1" Background="{StaticResource SurfaceBg}">
        <!-- 欢迎 -->
        <StackPanel x:Name="WelcomePanel" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
          <Border Width="88" Height="88" CornerRadius="20" Background="#F5F5F7" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Image x:Name="LogoImage" Stretch="Uniform" Margin="14" />
          </Border>
          <TextBlock Text="XCAGI"
                     FontFamily="{StaticResource FontFamilyDisplay}"
                     FontSize="26"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimary}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="8.0 · 企业 AI 员工宿主"
                     FontSize="13"
                     Foreground="{StaticResource TextMuted}"
                     HorizontalAlignment="Center"
                     Margin="0,6,0,32" />

          <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="72" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="位置" FontSize="13" Foreground="{StaticResource TextLight}" Margin="0,0,0,10" />
            <TextBlock x:Name="WelcomePathPreview"
                       Grid.Row="0" Grid.Column="1"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text, ElementName=WelcomePathPreview}"
                       FontSize="13"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,10" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="空间" FontSize="13" Foreground="{StaticResource TextLight}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="约 1.5 GB" FontSize="13" Foreground="{StaticResource TextPrimary}" />
          </Grid>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <CheckBox x:Name="WelcomeAgreeCheck"
                      Style="{StaticResource ModernCheckBoxStyle}"
                      Content="同意"
                      VerticalAlignment="Center" />
            <Button Content="软件许可协议"
                    Style="{StaticResource LinkButtonStyle}"
                    Click="ViewLicense_OnClick"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center" />
          </StackPanel>
          <Button Content="更改安装位置"
                  Style="{StaticResource LinkButtonStyle}"
                  Click="CustomizePath_OnClick"
                  HorizontalAlignment="Center"
                  Margin="0,14,0,0" />
        </StackPanel>

        <!-- 许可 -->
        <Grid x:Name="LicensePanel" Visibility="Collapsed" Margin="40,32">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="软件许可协议"
                     FontFamily="{StaticResource FontFamilyDisplay}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Margin="0,0,0,16" />
          <Border Grid.Row="1" Background="#F5F5F7" BorderBrush="{StaticResource Separator}" BorderThickness="1" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
              <TextBlock x:Name="LicenseTextBlock"
                         TextWrapping="Wrap"
                         FontFamily="{StaticResource FontFamilyPrimary}"
                         FontSize="12"
                         Foreground="#3A3A3C"
                         LineHeight="20" />
            </ScrollViewer>
          </Border>
          <CheckBox x:Name="AgreeLicenseCheck"
                    Grid.Row="2"
                    Style="{StaticResource ModernCheckBoxStyle}"
                    Content="我同意此协议"
                    Margin="0,16,0,0" />
        </Grid>

        <!-- 目录 -->
        <StackPanel x:Name="DirectoryPanel" Visibility="Collapsed" VerticalAlignment="Center" Margin="48,0" MaxWidth="440">
          <TextBlock Text="安装位置"
                     FontFamily="{StaticResource FontFamilyDisplay}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Margin="0,0,0,6" />
          <TextBlock Text="可将应用安装到以下文件夹。"
                     FontSize="13"
                     Foreground="{StaticResource TextMuted}"
                     Margin="0,0,0,20" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InstallDirBox" Style="{StaticResource ModernTextBoxStyle}" />
            <Button Grid.Column="1" Content="选取…" Margin="10,0,0,0" Click="BrowseDir_OnClick" Style="{StaticResource SecondaryButtonStyle}" />
          </Grid>
          <StackPanel Margin="0,20,0,0">
            <CheckBox x:Name="DesktopShortcutCheck"
                      Style="{StaticResource ModernCheckBoxStyle}"
                      Content="创建桌面快捷方式"
                      IsChecked="True"
                      Margin="0,0,0,8" />
            <CheckBox x:Name="RunAfterInstallCheck"
                      Style="{StaticResource ModernCheckBoxStyle}"
                      Content="安装完成后打开 XCAGI"
                      IsChecked="True" />
          </StackPanel>
        </StackPanel>

        <!-- 安装中 -->
        <StackPanel x:Name="InstallingPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
          <TextBlock x:Name="InstallPercentText"
                     Text=""
                     FontSize="36"
                     FontWeight="Light"
                     Foreground="{StaticResource TextPrimary}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,20"
                     Visibility="Collapsed" />
          <ProgressBar x:Name="InstallProgress"
                       Style="{StaticResource ModernProgressBarStyle}"
                       Minimum="0"
                       Maximum="100"
                       Value="0"
                       IsIndeterminate="False"
                       Margin="0,0,0,14" />
          <TextBlock x:Name="InstallStatusText"
                     Text="正在安装…"
                     HorizontalAlignment="Center"
                     FontSize="13"
                     Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <!-- 完成 -->
        <StackPanel x:Name="CompletePanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
          <TextBlock Text="✓"
                     FontSize="48"
                     FontWeight="Light"
                     Foreground="{StaticResource AccentGreen}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,12" />
          <TextBlock Text="安装成功"
                     FontFamily="{StaticResource FontFamilyDisplay}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,8" />
          <TextBlock x:Name="CompletePathText"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource TextMuted}"
                     Margin="0,0,0,8" />
          <TextBlock x:Name="CompleteExtrasText"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <!-- 错误 -->
        <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
          <TextBlock Text="无法安装"
                     FontFamily="{StaticResource FontFamilyDisplay}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ErrorRed}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,10" />
          <TextBlock x:Name="ErrorMessageText"
                     TextWrapping="Wrap"
                     FontSize="13"
                     LineHeight="20"
                     Foreground="{StaticResource TextMuted}"
                     TextAlignment="Center" />
        </StackPanel>
      </Grid>

      <!-- 底栏 -->
      <Grid Grid.Row="2" Background="{StaticResource SurfaceBg}">
        <Border BorderBrush="{StaticResource Separator}" BorderThickness="0,1,0,0" />
        <Grid Margin="24,0">
          <Button x:Name="CancelButton"
                  Content="取消"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Click="Cancel_OnClick"
                  Style="{StaticResource GhostButtonStyle}" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button x:Name="BackButton"
                    Content="返回"
                    Margin="0,0,12,0"
                    Visibility="Collapsed"
                    Click="Back_OnClick"
                    Style="{StaticResource GhostButtonStyle}" />
            <Button x:Name="NextButton"
                    Content="继续"
                    Click="Next_OnClick"
                    Style="{StaticResource HeroButtonStyle}" />
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
