# 法大大电子签 — 复制到 FHD/.env 或 FHD/XCAGI/.env 后填写真实值
# 模板文件准备：.venv/bin/python scripts/build_contract_template_docx.py
# 说明文档：data/contracts/xcagi_service_v1/fadada/法大大签署模板配置指南.md

ESIGN_PROVIDER=fadada

# 开放平台应用
FADADA_APP_ID=
FADADA_APP_SECRET=
FADADA_SERVER_URL=https://api.fadada.com/api/v5

# 乙方（成都修茈）企业 openCorpId — 企业认证后获取
FADADA_OPEN_CORP_ID=

# 控制台「签署模板」ID（跨环境导入或上传 template 后，在模板详情中复制）
FADADA_SIGN_TEMPLATE_ID=

# 跨环境导入凭证见 data/contracts/xcagi_service_v1/fadada/import_template.local.env（勿提交 Git）

# 客户签署方在模板中的 actorId，须与法大大模板一致（默认甲方）
FADADA_SIGN_ACTOR_ID=甲方

# 公网回调（须 HTTPS）
FADADA_CALLBACK_URL=https://你的域名/api/contract-lifecycle/esign/webhook

# 可选：客户签署完成前的 H5 门户（未配置时由 API 返回 actorSignTaskUrl）
# FADADA_SIGN_PORTAL_URL=
