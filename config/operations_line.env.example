# 运营线打通 · 环境变量（复制到 FHD/.env 与 MODstore_deploy/.env.local）
# 本地：FHD :5000，MODstore :8765；生产请改为公网/内网真实地址。

# ── FHD ─────────────────────────────────────────
# 修茈市场 API 根（无尾斜杠）；支付代理会请求 {BASE}/api/market/payment/*
XCAGI_MARKET_BASE_URL=https://xiu-ci.com
# 或本地 MODstore：http://127.0.0.1:8765

MODEL_PAYMENT_BACKEND=modstore

# 官网需求表单 / 审核码 / MODstore 内部 API（与 MODstore 侧保持一致）
XCAGI_CS_INTAKE_LINK_SECRET=xcagi-cs-intake-dev-secret
XCAGI_CS_INTAKE_WEBHOOK_SECRET=xcagi-cs-intake-dev-secret
XCAGI_MARKET_INTERNAL_API_KEY=xcagi-cs-intake-dev-secret

# 合同电子签（默认自建，不必接法大大）
# stub = 自建签署页 /contract/sign/{taskId} + 状态机（推荐）
# fadada = 可选法大大 FASC OpenAPI
ESIGN_PROVIDER=stub
# 客户打开的签署页根地址（前端），本地示例 http://127.0.0.1:5001
# ESIGN_STUB_PUBLIC_BASE_URL=http://127.0.0.1:5001
# ESIGN_STUB_SIGN_SECRET=随机长字符串
# ESIGN_PROVIDER=fadada
# FADADA_APP_ID=
# FADADA_APP_SECRET=
# FADADA_OPEN_CORP_ID=
# FADADA_SIGN_TEMPLATE_ID=
# FADADA_SERVER_URL=https://api.fadada.com/api/v5
# FADADA_SIGN_ACTOR_ID=甲方
# FADADA_CALLBACK_URL=https://你的公网域名/api/contract-lifecycle/esign/webhook

# 合同到期扫描（每日，需应用侧调用 maybe_run_contract_expiry_cron 或 POST /api/operations-line/contracts/scan-expiry）
# CONTRACT_EXPIRY_CRON_ENABLED=1
# CONTRACT_EXPIRY_DAYS_AHEAD=30

# 外部 CRM 副本（可选）：hubspot | salesforce
# EXTERNAL_CRM_PROVIDER=hubspot
# HUBSPOT_ACCESS_TOKEN=
# EXTERNAL_CRM_PROVIDER=salesforce
# SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
# SALESFORCE_ACCESS_TOKEN=
# SALESFORCE_API_VERSION=59.0
# SALESFORCE_DEFAULT_ACCOUNT_ID=
# 若组织 StageName 与默认不同，可 JSON 覆盖：
# SALESFORCE_PIPELINE_TO_STAGE_JSON={"idle":"Prospecting"}
# SALESFORCE_STAGE_TO_PIPELINE_JSON={"Prospecting":"idle"}

# 税务开票：stub | baiwang
TAX_INVOICE_PROVIDER=stub

# ── MODstore（生产直切 Java 支付，与 FHD MODEL_PAYMENT_BACKEND=modstore 配套）──
# PAYMENT_BACKEND=java
# JAVA_PAYMENT_SERVICE_URL=http://payment-service:8080
# MODSTORE_INTERNAL_API_KEY=<与 XCAGI_MARKET_INTERNAL_API_KEY 相同>
# ALIPAY_NOTIFY_URL=https://xiu-ci.com/api/payment/notify/alipay
# 切换：MODstore_deploy/scripts/production_flip_payment_backend_java.sh

# ── MODstore ────────────────────────────────────
# FHD 内网地址（官网联系表单 webhook 目标）
XCAGI_FHD_INTERNAL_URL=http://127.0.0.1:5000
# 生产示例：https://xiu-ci.com 或 http://内网IP:5000

XCAGI_CS_BRIDGE_MOD_ID=xcagi-customer-service-bridge
XCAGI_CS_INTAKE_WEBHOOK_SECRET=xcagi-cs-intake-dev-secret
XCAGI_CS_INTAKE_LINK_SECRET=xcagi-cs-intake-dev-secret

# Webhook 出站队列数据目录
MODSTORE_DATA_DIR=/tmp/modstore_data

# MODstore → FHD 运营线事件（可选）
# XCAGI_OPS_LINE_HOOK_SECRET=xcagi-ops-line-dev-secret

# ── 制作线 P1–P10（FHD ↔ MODstore 共用密钥须一致）────────────────
# 遥测 ingest：FHD telemetry_production_bridge → MODstore /api/internal/telemetry/ingest
XCAGI_TELEMETRY_INGEST_SECRET=xcagi-telemetry-dev-secret

# MODstore 进程侧（.env.local）还需：
# MODSTORE_CR_GIT_AUTO_PR=1
# MODSTORE_GITHUB_WEBHOOK_SECRET=<GitHub Webhook Secret>
# MODSTORE_RUN_BACKGROUND_JOBS=1

# GitHub Actions（在仓库 Settings 配置，勿写入 .env 提交）：
# MODSTORE_ORCHESTRATE_URL=https://xiu-ci.com/api/ops/orchestrate/async
# MODSTORE_ORCHESTRATE_TOKEN=<管理员 Bearer>
# MODSTORE_PRODUCTION_LINE_EVENT_URL=https://xiu-ci.com/api/admin/production-line/event
# DEPLOY_MARKETING_REMOTE_DIR=/root/成都修茈科技有限公司
# DEPLOY_DOCS_REMOTE_DIR=/var/www/docs.xiu-ci.com
# DEPLOY_BG_AUTO_PROMOTE=true

# 安装与验证：见 FHD/docs/guides/PRODUCTION_LINE_SETUP.md
#   bash FHD/scripts/setup-production-line.sh
#   bash FHD/scripts/verify_production_line_config.sh

# 全景页 live 刷新（打开 XCAGI-Full-Pipeline.html 前在控制台设置，或见 HTML 内注释）
# window.XCAGI_OPS_HEALTH_URL = 'http://127.0.0.1:8765'
