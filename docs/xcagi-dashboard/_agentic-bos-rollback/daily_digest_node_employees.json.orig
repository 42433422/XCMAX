      "support": ["dbops-engineer"]
    },
    "CENT": {
      "name": "day_index % 100 = 0?",
      "primary": ["daily-orchestrator"],
      "support": ["deploy-release-officer", "change-request-auditor"]
    },
    "MAJ": {
      "name": "major 大推送 1.N.0.0",
      "primary": ["deploy-release-officer"],
      "support": ["push-update-context-officer", "change-request-auditor"],
      "six_line": [{ "line": "prod_software", "step": "P5" }]
    },
    "V": {
      "name": "Vibe 预备 更新+补丁 MD",
      "primary": ["vibe-coding-maintainer", "task-router-officer"],
      "support": ["daily-orchestrator", "fhd-core-maintainer"],
      "six_line": [{ "line": "prod_software", "step": "P10" }]
    },
    "ACT": {
      "name": "双清单解析 → daily_action_items",
      "scope": "digest_action_items.parse_and_store_action_items · 同日 dedupe_key 幂等",
      "primary": ["daily-orchestrator", "modstore-backend-api"],
      "support": ["vibe-coding-maintainer", "dbops-engineer"]
    },
    "GAPS": {
      "name": "断点清单 · AI 补丁看板",
