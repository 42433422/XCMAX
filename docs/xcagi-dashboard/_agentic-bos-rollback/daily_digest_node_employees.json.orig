{
  "version": "2026-06-06",
  "description": "日更全链路架构图节点 → 主责/协作员工（与 six_line_employee_map 对齐，可叠加 six_line 引用）",
  "employee_labels": {
    "daily-orchestrator": "每日编排员",
    "workbench-ux-stylist": "工作台体验",
    "task-router-officer": "任务路由官",
    "retention-officer": "归档清理员",
    "legacy-archive-curator": "遗留归档员",
    "log-monitor-incident": "日志监控员",
    "security-secrets-guard": "密钥门禁员",
    "site-content-editor": "网站内容编辑",
    "marketing-site-builder": "营销站构建",
    "seo-sitemap-curator": "SEO 站点图",
    "market-frontend-dev": "市场前端开发",
    "fhd-core-maintainer": "FHD 核心维护",
    "vibe-coding-maintainer": "Vibe 编码维护",
    "test-qa-runner": "测试质检员",
    "deploy-release-officer": "发布交付官",
    "push-update-context-officer": "OTA 推送官",
    "mobile-android-release-officer": "Android 发布",
    "mobile-ios-release-officer": "iOS 发布",
    "pack-registrar": "打包登记员",
    "dbops-engineer": "数据库运维",
    "modstore-backend-api": "MODstore 后端",
    "doc-knowledge-curator": "文档知识库",
    "nginx-config-engineer": "Nginx 工程师",
    "change-request-auditor": "变更审计员",
    "intake-dispatcher": "需求分发员",
    "employee-planner": "员工规划师",
    "intent-analyst": "意图分析师",
    "host-checker": "主机巡检员"
  },
  "nodes": {
    "daily-hub": {
      "name": "日更闭环",
      "primary": ["daily-orchestrator"],
      "support": ["task-router-officer", "deploy-release-officer"]
    },
    "R": {
      "name": "03:15 retention-officer 归档清理",
      "primary": ["retention-officer"],
      "support": ["legacy-archive-curator"],
      "six_line": [{ "line": "shared_retention", "step": "R1" }]
    },
    "K": {
      "name": "运维 KPI · 待审 · TLS · IMAP",
      "primary": ["log-monitor-incident", "security-secrets-guard"],
      "support": ["daily-orchestrator"],
      "six_line": [{ "line": "shared_retention", "step": "R4" }]
    },
    "SW": {
      "name": "P-W 网站截图+分析",
      "primary": ["site-content-editor", "marketing-site-builder"],
      "support": ["seo-sitemap-curator"],
      "six_line": [{ "line": "prod_web", "step": "P1a" }]
    },
    "SS": {
      "name": "P-S 软件截图+分析",
      "primary": ["fhd-core-maintainer", "test-qa-runner"],
      "support": ["market-frontend-dev", "workbench-ux-stylist"],
      "six_line": [{ "line": "prod_software", "step": "P3" }]
    },
    "SA": {
      "name": "P-App 移动/WebView 截图+分析",
