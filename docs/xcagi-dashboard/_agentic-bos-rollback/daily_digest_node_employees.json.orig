      "primary": ["mobile-android-release-officer", "mobile-ios-release-officer"],
      "support": ["workbench-ux-stylist"],
      "six_line": [{ "line": "prod_software", "step": "P4" }]
    },
    "M": {
      "name": "员工大会 → 会议摘要",
      "primary": ["workbench-ux-stylist", "task-router-officer"],
      "support": ["daily-orchestrator", "vibe-coding-maintainer"],
      "six_line": [{ "line": "prod_web", "step": "P1c" }]
