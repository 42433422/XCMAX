{
  "name": "xcagi-frontend",
  "private": true,
  "version": "8.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "node --require ./vite-polyfill.cjs ./node_modules/vite/bin/vite.js dev",
    "build": "vite build --mode generic",
    "build:full": "vite build",
    "build:generic": "vite build --mode generic",
    "build:minimal": "vite build --mode minimal",
    "build:strict": "vue-tsc --noEmit -p tsconfig.build.json && vite build",
    "build:generic:strict": "vue-tsc --noEmit -p tsconfig.build.json && vite build --mode generic",
    "build:minimal:strict": "vue-tsc --noEmit -p tsconfig.build.json && vite build --mode minimal",
    "type-check:build": "vue-tsc --noEmit -p tsconfig.build.json",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "type-check:watch": "vue-tsc --noEmit --watch",
    "test": "node --require ./vitest.polyfill.cjs ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --require ./vitest.polyfill.cjs ./node_modules/vitest/vitest.mjs",
    "test:smoke": "node --require ./vitest.polyfill.cjs ./node_modules/vitest/vitest.mjs run tests/smoke",
    "test:smoke:watch": "node --require ./vitest.polyfill.cjs ./node_modules/vitest/vitest.mjs tests/smoke",
    "test:coverage": "node --require ./vitest.polyfill.cjs ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:smoke:5001": "playwright test e2e/smoke.spec.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@element-plus/icons-vue": "^2.3.2",
    "@huggingface/transformers": "^3.8.1",
    "dompurify": "^3.2.4",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "font-awesome": "^4.7.0",
    "mime-types": "^2.1.35",
    "pinia": "^2.2.2",
    "qrcode": "^1.5.4",
    "vue": "^3.4.21",
    "vue-router": "^4.4.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.5.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.0.5",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^17.6.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.4.2",
    "vitest": "^2.0.5",
    "vue-tsc": "^2.0.29"
  }
}
