{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "DORA four-key metrics (deployment frequency, lead time, change failure rate, MTTR). Fed by scripts/dora_metrics.py textfile exporter.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "XCAGI · DORA Metrics",
  "tags": ["xcagi", "dora", "release"],
  "timezone": "browser",
  "time": {"from": "now-30d", "to": "now"},
  "refresh": "5m",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Deployment Frequency (per day)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.143},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {"expr": "dora_deployment_frequency_per_day", "legendFormat": "deploys/day", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Lead Time for Changes (median hours)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 24},
              {"color": "red", "value": 168}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {"expr": "dora_lead_time_hours_median", "legendFormat": "lead time (h)", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Change Failure Rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.15},
              {"color": "red", "value": 0.30}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {"expr": "dora_change_failure_rate", "legendFormat": "CFR", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "MTTR (median hours)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 24}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {"expr": "dora_mttr_hours_median", "legendFormat": "MTTR (h)", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Deployment Frequency trend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "dora_deployment_frequency_per_day", "legendFormat": "deploys/day", "refId": "A"},
        {"expr": "dora_total_deploys", "legendFormat": "total deploys (window)", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "Change Failure Rate & MTTR trend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "dora_change_failure_rate", "legendFormat": "CFR (0..1)", "refId": "A"},
        {"expr": "dora_mttr_hours_median", "legendFormat": "MTTR (h)", "refId": "B"}
      ]
    }
  ]
}
