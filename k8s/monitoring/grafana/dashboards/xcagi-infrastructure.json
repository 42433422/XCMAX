{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "type": "dashboard"}]},
  "description": "Infrastructure: CPU, memory, disk, pod status, network. XCAGI backend + workers.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "XCAGI · Infrastructure",
  "tags": ["xcagi", "infrastructure", "k8s"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {"name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}}
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pod CPU usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"drawStyle": "line", "fillOpacity": 10}, "max": 1, "min": 0}},
      "targets": [
        {"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{pod=~\"xcagi.*\",container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Pod memory usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "sum by (pod) (container_memory_usage_bytes{pod=~\"xcagi.*\",container!=\"\"})", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Pod restarts (last 1h)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{pod=~\"xcagi.*\"}[1h]))", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Disk usage (root)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}}},
      "targets": [
        {"expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"\\/\"})", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Network throughput",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 8},
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "sum(rate(container_network_receive_bytes_total{pod=~\"xcagi.*\"}[5m]))", "legendFormat": "rx", "refId": "A"},
        {"expr": "sum(rate(container_network_transmit_bytes_total{pod=~\"xcagi.*\"}[5m]))", "legendFormat": "tx", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "Pod status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 15},
      "targets": [
        {"expr": "sum by (pod, phase) (kube_pod_status_phase{pod=~\"xcagi.*\"})", "format": "table", "instant": true, "refId": "A"}
      ]
    }
  ]
}
