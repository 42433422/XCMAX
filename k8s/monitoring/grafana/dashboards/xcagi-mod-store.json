{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "type": "dashboard"}]},
  "description": "Mod store: catalog RPS, mod load success rate, per-mod DB copies, scan duration.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "xcagi-mod-store",
  "title": "XCAGI · Mod Store",
  "tags": ["xcagi", "mod-store", "mods"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {"name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}}
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Catalog RPS",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "sum by (endpoint) (rate(api_requests_total{job=\"xcagi-backend\",endpoint=~\"/api/mod-store/.*\"}[1m]))", "legendFormat": "{{endpoint}}", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Mod load success rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.85}, {"color": "green", "value": 0.95}]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(mod_load_total{status=\"ok\"}[5m])) / clamp_min(sum(rate(mod_load_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Mods loaded",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "max(mod_loaded_count)", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Mod scan duration (P95)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(mod_scan_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "scan p95", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Per-mod SQLite DB copies",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "sum by (mod_id) (mod_sqlite_copy_present)", "legendFormat": "{{mod_id}}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "Mod activation header rejections",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "bars", "fillOpacity": 60}}},
      "targets": [
        {"expr": "sum by (reason) (rate(mod_active_header_rejected_total[1m]))", "legendFormat": "{{reason}}", "refId": "A"}
      ]
    }
  ]
}
