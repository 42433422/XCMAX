{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "type": "dashboard"}]},
  "description": "NeuroBus: domain activity, intent recognition latency, circuit breaker state, dropped events.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "xcagi-neurobus",
  "title": "XCAGI · NeuroBus",
  "tags": ["xcagi", "neuro-bus", "intent"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {"name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"}}
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Events / sec by domain",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "sum by (domain) (rate(neuro_bus_events_total[1m]))", "legendFormat": "{{domain}}", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Dropped events by reason",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 30}}},
      "targets": [
        {"expr": "sum by (reason) (rate(neuro_bus_events_dropped_total[1m]))", "legendFormat": "{{reason}}", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Intent recognition latency (P95)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(neuro_bus_intent_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "intent p95", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Circuit breaker state",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}, "1": {"text": "HALF-OPEN", "color": "yellow"}, "2": {"text": "OPEN", "color": "red"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}
        }
      },
      "targets": [
        {"expr": "max by (name) (circuit_breaker_state)", "legendFormat": "{{name}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Domain processing time P95",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, domain) (rate(neuro_bus_domain_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "{{domain}}", "refId": "A"}
      ]
    }
  ]
}
