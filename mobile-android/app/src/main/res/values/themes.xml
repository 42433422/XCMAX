<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.XCAGI" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/xiuci_bg_dark</item>
        <item name="android:navigationBarColor">@color/xiuci_bg_dark</item>
        <item name="android:windowBackground">@color/xiuci_bg_dark</item>
