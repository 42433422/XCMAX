{
  "id": "xcagi-model-payment-bridge",
  "name": "模型付费桥接 Mod",
  "version": "1.3.0",
  "author": "成都修茈科技有限公司",
  "description": "模型付费 API 门面（J）+ 业务页（K/O+ 物理视图在 Mod 包）。",
  "dependencies": { "xcagi": ">=10.0.0" },
  "backend": { "entry": "blueprints", "init": "mod_init" },
  "frontend": {
    "routes": "frontend/routes",
    "menu": [
      {
        "id": "mod-kitten-finance",
        "label": "财务分析",
        "icon": "fa-line-chart",
        "path": "/mod/xcagi-model-payment-bridge/kitten-finance"
      }
    ],
    "menu_overrides": [
      { "key": "model-payment", "hidden": true },
      { "key": "kitten-finance", "hidden": true }
    ]
  },
  "hooks": {},
  "comms": { "exports": [] },
  "config": {
    "model_payment_facade": true,
    "model_payment_pages_via_mod": true,
    "views_physical": true,
    "physical_views": ["ModelPaymentView.vue", "KittenFinanceView.vue"],
    "legacy_host_prefixes": ["/api/model-payment"],
    "legacy_host_page_paths": ["/model-payment", "/kitten-finance"],
    "phase": "O+"
  }
}
