# /etc/xcmax-ops.env —— XCMAX 运维工具包配置（shell 可 source，KEY=VALUE，勿留空格）
# install.sh 首次安装时复制本模板到 /etc/xcmax-ops.env（chmod 600），按需修改。

# ---- 告警 ----
# 告警收件邮箱（默认老板邮箱）
OPS_ALERT_EMAIL_TO=ler231573@gmail.com
# SMTP 凭证默认自动回落读取 MODstore .env 的 MODSTORE_SMTP_*（生产已配 QQ SMTP），
# 如需独立发信账号再取消注释：
#OPS_SMTP_HOST=smtp.qq.com
#OPS_SMTP_PORT=465
#OPS_SMTP_USER=
#OPS_SMTP_PASSWORD=
# 可选：额外 webhook（Server酱/企业微信机器人等任意收 JSON POST 的 URL）
#OPS_WEBHOOK_URL=

# ---- 服务拓扑（与生产 119.27.178.147 现状一致，变更时改这里） ----
OPS_FHD_PORT=5100
OPS_MODSTORE_PORT=9999
OPS_SCHEDULER_PORT=9990
OPS_PAYMENT_PORT=8080
OPS_PAYMENT_ENABLED=1
OPS_UNITS=fhd-full,modstore,modstore-scheduler,nginx
OPS_DOMAIN=xiu-ci.com

# ---- 路径 ----
OPS_XCMAX_ROOT=/root/XCMAX
OPS_FHD_DEPLOY_ROOT=/opt/fhd-full
OPS_FHD_ENV=/root/fhd-full.env
OPS_MODSTORE_DIR=/root/XCMAX/成都修茈科技有限公司/MODstore_deploy
OPS_MANIFEST=/var/www/update/releases/stable/server/fhd-manifest.json
OPS_BACKUP_DIR=/var/backups/xcmax
OPS_STATE_DIR=/var/lib/xcmax-ops
OPS_LOG_DIR=/var/log/xcmax-ops

# ---- 备份异地（强烈建议配置；pip3 install coscmd && coscmd config 后填桶名） ----
#OPS_COS_BUCKET=
# 额外要进 configs 备份的路径（空格分隔）
#OPS_BACKUP_EXTRA=

# ---- 阈值（有默认，一般不用动） ----
#OPS_REALERT_HOURS=24
#OPS_JOURNAL_ERR_WARN=30
#OPS_JOURNAL_ERR_CRIT=200
#OPS_QUOTA_BURST_WARN=5
#OPS_DISK_WARN=88
#OPS_DISK_CRIT=95

# ---- 安装器行为 ----
# 1 = install.sh 同时安装 FHD 拉取式自动更新 cron（接通既有发布链，推荐）
OPS_INSTALL_FHD_AUTOUPDATE=1
