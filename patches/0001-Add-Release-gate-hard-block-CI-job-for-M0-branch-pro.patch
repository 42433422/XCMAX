+
+  release-gate:
+    name: Release gate (hard block)
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: ${{ env.PYTHON_VERSION }}
+          cache: pip
+      - name: Install test deps
+        run: python -m pip install -U pip pytest pytest-mock
+      - name: Release contract tests (isolated conftest)
+        run: python -m pytest tests/release/ --confcutdir=tests/release -q --tb=short
+      - name: Release gate manifest
+        run: python -m pytest tests/release_gate/ -q --tb=short
+
