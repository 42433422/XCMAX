# 复制为 demo.local.env（已在 .gitignore）后 source，或合并进仓根 .env
#   cp scripts/ai_agent_v0/demo.local.env.example scripts/ai_agent_v0/demo.local.env
#
# Mock（无 PostgreSQL）：仅验证 plan → engine 桩工具
# AI_AGENT_V0_MOCK_TOOLS=1
#
# Live 工具链（需 DATABASE_URL 可达，planner 仍可无 Key 用 fallback）：
AI_AGENT_V0_LIVE_TOOLS=1
unset AI_AGENT_V0_MOCK_TOOLS
