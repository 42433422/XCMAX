# Copy to upload-release.env (gitignored) and dot-source before upload:
#   . .\scripts\package\upload-release.env
#   powershell -File scripts\package\upload-release-skus.ps1 -Version 8.0.0

XCAGI_UPDATE_SSH_HOST=update.xcagi.com
XCAGI_UPDATE_SSH_USER=deploy
XCAGI_UPDATE_SSH_PATH=/var/www/update/releases/stable
# XCAGI_UPDATE_SSH_KEY=C:\Users\you\.ssh\id_ed25519

# Optional: sign latest.yml at build time
# XCAGI_UPDATE_ED25519_PRIVATE_KEY=
