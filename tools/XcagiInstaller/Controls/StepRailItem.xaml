<UserControl x:Class="XcagiInstaller.Controls.StepRailItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40">
  <Grid Margin="0,0,0,2">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="28" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid Grid.Column="0">
      <Rectangle x:Name="ConnectorTop" Width="2" Height="12" Fill="#66FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-8,0,0" Visibility="Collapsed" />
      <Border x:Name="StepBadge" Width="22" Height="22" CornerRadius="11" Background="#33FFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="StepNumber" Text="1" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Rectangle x:Name="ConnectorBottom" Width="2" Height="16" Fill="#44FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10" />
    </Grid>
    <TextBlock x:Name="StepLabel" Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="#99FFFFFF" Text="步骤" />
  </Grid>
</UserControl>
