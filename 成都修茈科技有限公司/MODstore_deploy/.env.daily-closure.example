# 日更闭环 · Git push/merge + 编排 primary 模式（v10 线内迭代）
# 用法：cp .env.daily-closure.example .env.daily-closure 后按需改路径
# run_modstore_daily_local.sh 会自动 source 本文件（在 .env.local 之后）
#
# 本地 SMTP/凭证：bash scripts/pull_prod_env_for_local.sh
#   → .env.production.synced + FHD/XCAGI/.env.smtp.local（均 gitignore，从服务器 SSH 拉取并改写路径/SQLite）

# monorepo git 根（须有 .git；本地 Mac 示例）
MODSTORE_REPO_ROOT=/Users/a4243342/Desktop/XCMAX
XCMAX_MONOREPO_ROOT=/Users/a4243342/Desktop/XCMAX

# Mac 主跑日更；CVM 设 PRIMARY=local_mac + ROLE=server（见 patch_prod_daily_closure.sh）
MODSTORE_AUTOMATION_PRIMARY=local_mac
MODSTORE_AUTOMATION_ROLE=local_mac

# merge/push 后立刻 SSH 拉服务器 main（可选；不设则靠 CVM cron 每 10 分钟拉取）
# MODSTORE_SYNC_DEPLOY_BASH=bash /path/to/MODstore_deploy/scripts/trigger_server_git_sync.sh

# 08:25 真编排（停用 07:00 shadow 盲跑）
MODSTORE_DAILY_ORCHESTRATOR_DIGEST_MODE=primary
MODSTORE_DAILY_ORCHESTRATOR_ENABLED=1

# 日更分支 → push → PR → merge
MODSTORE_AUTO_PR_ENABLED=1
MODSTORE_AUTO_PR_BASE_BRANCH=main
MODSTORE_DEPLOY_PUSH_REMOTE=origin
MODSTORE_DEPLOY_PUSH_BRANCH_PREFIX=auto/daily-

# 低风险 OpsStagedChange 零人工（须配合 SLO halt 安全网）
MODSTORE_OPS_STAGED_AUTO_APPROVE=1
MODSTORE_OPS_STAGED_AUTO_MAX_FILES=24
MODSTORE_SLO_HALT_AUTO_MERGE=1
MODSTORE_RELEASE_SLO_HALT=1

# CR → git 分支 → gh PR → CI auto-merge
MODSTORE_CR_GIT_BRANCH_ENABLED=1
MODSTORE_CR_GIT_APPLY_COMMIT=1
MODSTORE_CR_GIT_AUTO_PR=1
MODSTORE_AUTO_APPROVE_ENABLED=1
MODSTORE_AUTO_APPROVE_REQUIRE_CI=1
MODSTORE_CR_NARROW_CI_ENABLED=1

# 邮件审批轮询 + 部署后 smoke
MODSTORE_INBOX_POLL_ENABLED=1
MODSTORE_POST_DEPLOY_SMOKE_ENABLED=1
MODSTORE_POST_DEPLOY_SMOKE_CRON_ENABLED=1
MODSTORE_DEPLOY_HEALTH_URL=http://127.0.0.1:8788/api/health
MODSTORE_POST_DEPLOY_MARKET_URL=https://xiu-ci.com/market/download

# 产线灰度：P-S primary
MODSTORE_LINE_PRIMARY_LINES=P-S
MODSTORE_LINE_SHADOW_LINES=P-W,P-App,S-R

# 容灾 + 截图依赖自动拉起
MODSTORE_DR_PROBE_ENABLED=1
MODSTORE_ONDEMAND_BACKUP_ENABLED=1
MODSTORE_SURFACE_AUDIT_AUTO_START=1
MODSTORE_SURFACE_AUDIT_ANDROID=1
SURFACE_AUDIT_PRODUCT_SKU=enterprise
SURFACE_AUDIT_ANDROID_FHD_HOST=10.0.2.2:5000
SURFACE_AUDIT_API_URL=http://127.0.0.1:5000
