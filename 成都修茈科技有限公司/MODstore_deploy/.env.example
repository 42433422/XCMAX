# MODstore 服务器配置
# 复制本文件为 .env 后填写真实值（.env 不会被提交到 Git）

# 可选：`docker compose --profile app build api` 时换 Debian 源，国内网络加速（无尾斜杠）
# APT_MIRROR=https://mirrors.aliyun.com

# ════════════════════════════════════════
# 邮箱验证码配置（QQ邮箱）
# ════════════════════════════════════════
# 1. 登录 https://mail.qq.com
# 2. 设置 → 账户 → 开启「POP3/SMTP服务」
# 3. 生成「授权码」（16位，不是QQ登录密码）

MODSTORE_SMTP_HOST=smtp.qq.com
MODSTORE_SMTP_PORT=465
MODSTORE_SMTP_USER=your-email@example.com
MODSTORE_SMTP_PASSWORD=your-qq-smtp-password
MODSTORE_SENDER_EMAIL=your-email@example.com
MODSTORE_SENDER_NAME=XC AGI

# 调试模式：设为 1 则验证码打印在控制台，不发送真实邮件
MODSTORE_EMAIL_DEBUG=1

# ════════════════════════════════════════
# 安全密钥
# ════════════════════════════════════════
# JWT 密钥（生产环境必须设置长随机字符串；留空则进程拒绝启动）
MODSTORE_JWT_SECRET=your-random-secret-key-change-in-production
# Refresh Token 有效期（天）。默认长期登录；用户主动退出会清除本机 token。
# MODSTORE_JWT_REFRESH_EXPIRE_DAYS=3650
# 仅本地一次性脚本：密钥为空时强行启动（禁止用于生产）
# MODSTORE_INSECURE_EMPTY_JWT=1
# 受信任集成开放注册 API：POST /api/market/open/register（公网生产默认关闭）
MODSTORE_OPEN_REGISTER_API=0

# 管理员线下直充 Token（用于给用户充值余额）
MODSTORE_ADMIN_RECHARGE_TOKEN=your-admin-token-change-this
# 同一 Token 可用于运维接口：POST /api/admin/reset-user-password（请求头 X-Modstore-Recharge-Token）

# 管理端「运维终端」SSH 提示（仅 GET /api/admin/ops-ssh-hint 对管理员返回；勿提交真实密码）
# MODSTORE_OPS_SSH_HOST=119.27.178.147
# MODSTORE_OPS_SSH_USER=root
# MODSTORE_OPS_SSH_PASSWORD=
# MODSTORE_OPS_SSH_COMMAND=ssh -o StrictHostKeyChecking=no root@119.27.178.147

# ════════════════════════════════════════
# 管理端解锁身份码：跨部署互通（可选）
# ════════════════════════════════════════
# 场景：每日摘要在自建 MODstore 生成，但管理员在公网 xiu-ci.com 市场解锁。
# —— 自建（签发库）须能从公网 HTTP(S) 访问到其 API 根 ——
# 1) 设置长随机串 MODSTORE_DIGEST_PEER_SERVICE_TOKEN（与公网侧相同）
# 2) MODSTORE_DIGEST_PEER_ENABLE_INBOUND=1 以开放 POST /api/internal/verify-digest-identity
# —— 公网（消费端）——
# MODSTORE_DIGEST_IDENTITY_UPSTREAM_URL=http://你的自建公网IP或域名:端口
# MODSTORE_DIGEST_PEER_SERVICE_TOKEN=与自建完全相同的值
# 注意：内部接口仅靠共享密钥保护，生产务必配合防火墙限制来源 IP；Token 泄露存在被枚举风险。
# 可复制片段：docs/runbooks/digest-peer-bridge.env.example

# ════════════════════════════════════════
# CORS 跨域配置
# ════════════════════════════════════════
# 本地开发默认地址
CORS_ORIGINS=http://localhost:5176,http://127.0.0.1:5176,http://localhost:4173,http://127.0.0.1:4173

# 生产环境示例（部署后改为你的域名）：
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 市场 → FHD 沙盒「推送并测试」POST /api/mod-store/install：须带 Bearer 以绕过沙盒 CSRF。
# 生产建议设为长随机串；留空则使用内置占位符 modstore-sandbox-push（须与沙盒 expectations 一致时可再收紧校验）。
# MODSTORE_SANDBOX_PUSH_BEARER=

# ════════════════════════════════════════
# 公网部署配置（可选）
# ════════════════════════════════════════
# 支付完成回跳地址前缀（协议+域名，无尾斜杠）
# MODSTORE_PUBLIC_ORIGIN=https://your-domain.com

# 前端路由前缀（与 Vite base 一致，默认 /market）
# MODSTORE_MARKET_PREFIX=/market

# ════════════════════════════════════════
# 部署档位（本地开发 / Mac mini 中间环境 / 生产）
# ════════════════════════════════════════
# 每台机器在 .env 或编排中显式设置；GET /api/health 返回 deploy_tier、git_sha、hostname。
# 取值：local | staging | production（别名 dev→local、sandbox→staging、prod→production）
# 本地开发：
# MODSTORE_DEPLOY_TIER=local
# Mac mini（staging Runner）：
# MODSTORE_DEPLOY_TIER=staging
# 生产服务器：
# MODSTORE_DEPLOY_TIER=production
# 构建/镜像可注入提交号，避免运行时 exec git（与 /api/health 的 git_sha 同源）：
# MODSTORE_GIT_SHA=
# 每日摘要「仓库分支 / 最新提交」：镜像内无 git 时必填其一组——
# - 推荐：同时设置 MODSTORE_GIT_BRANCH 与 MODSTORE_GIT_COMMIT（完整 SHA 或短 SHA 均可）；
# - 或仅设 MODSTORE_GIT_SHA 作提交号，再单独设 MODSTORE_GIT_BRANCH；
# - 或构建时写入 /app/.modstore_build.json（见 modstore_build.json.example，可 bind 挂载）。
# `docker compose --profile app build` 会把下两变量传入 Dockerfile 写入镜像；compose up 时也会注入到 api/scheduler 环境。
# MODSTORE_GIT_BRANCH=main
# MODSTORE_GIT_COMMIT=
# 仓库根路径（强烈建议显式设置；用于 git 解析、运维白名单、CR 分支落地、每日岗位简报节选）
# 须指向 monorepo 根目录，且存在 yuangon/<area>/<pkg_id>/（例如 yuangon/site-and-marketing/flask-entry-keeper）。
# AI 员工"全权全量管理"的根目录即此路径；每位员工的 workspace_policy.scope_globs 在该根之下生效。
# Docker 内路径要与挂载一致；仅 clone 了 MODstore_deploy 而未含 yuangon 时，简报会提示「未找到本岗仓库目录」。
# Linux/macOS 示例：MODSTORE_REPO_ROOT=/root/成都修茈科技有限公司
# Windows 本地开发示例：MODSTORE_REPO_ROOT=E:\成都修茈科技有限公司
# MODSTORE_REPO_ROOT=

# 员工工作区运行时根（per-employee workspace；与 MODSTORE_REPO_ROOT 不同——这里只放临时构件/草稿）
# Linux 默认 /tmp/modstore_runtime；Windows 必须显式设置一个真实可写目录
# 示例：MODSTORE_RUNTIME_DIR=E:\modstore_runtime
# MODSTORE_RUNTIME_DIR=

# 工作台「给员工处理」POST /api/employees/{id}/execute-file 单文件上限（字节）。
# 默认 104857600（100MB）。须同步调大 market/nginx.conf 的 client_max_body_size。
# MODSTORE_EMPLOYEE_FILE_MAX_BYTES=104857600

# 工作台「我的素材」POST /api/workbench/studio-assets 单文件上限（字节）；未设置时与 MODSTORE_EMPLOYEE_FILE_MAX_BYTES 相同逻辑（默认 100MB）。
# MODSTORE_STUDIO_ASSET_MAX_BYTES=104857600
# 用户素材文件落盘根目录（默认 ./var）；生产请指向持久卷。
# MODSTORE_DATA_DIR=

# 太阳鸟考勤员（taiyangniao-attendance-employee）：本机 taiyangniao-pro 的 backend 目录（须存在 taiyangniao_attendance 子目录）。
# 若不设置，execute-file 会尝试 MODSTORE_REPO_ROOT/mods/taiyangniao-pro/backend（及容器内 MODstore_deploy 同级 mods）。
# Linux 示例：
# TAIYANGNIAO_BACKEND_PATH=/root/成都修茈科技有限公司/mods/taiyangniao-pro/backend

# ════════════════════════════════════════
# 支付后端切换（Python 兼容代理 → Java）
# ════════════════════════════════════════
# 设为 java 后，FastAPI 网关把 /api/payment、/api/wallet、/api/refunds
# 透传给 Java 支付服务；Python 本地 payment_orders/alipay_service 仅作只读兜底。
# 默认（python）保留旧行为，便于本地开发或灰度回滚。
PAYMENT_BACKEND=python
JAVA_PAYMENT_SERVICE_URL=http://127.0.0.1:8080
# Java 支付服务：当 SPRING_PROFILES_ACTIVE 包含 prod 时，禁止使用占位密钥启动。
# 必须设置强随机 PAYMENT_SECRET_KEY（不可为 default_secret_key）与 MODSTORE_JWT_SECRET（不可为文档中的 dev 默认值）。
# PAYMENT_SECRET_KEY=
# SPRING_PROFILES_ACTIVE=prod

# ════════════════════════════════════════
# LLM 平台密钥（可选，用于钱包「平台密钥」磁贴；用户 BYOK 优先）
# 小米 MiMo：控制台 https://platform.xiaomimimo.com/
# —— 重要：代码里 provider 为 xiaomi（勿写 mimo）；模型推荐 mimo-v2.5-pro
# —— Token Plan 密钥格式 tp-xxxxx，须与订阅页「专属 Base URL」集群一致（cn/sgp/ams）
# 以下三选一即可（与 modstore_server/llm_key_resolver.py 一致）：
# MIMO_API_KEY=
# XIAOMI_API_KEY=
# XIAOMI_MIMO_API_KEY=
# 可选覆盖网关（默认 https://token-plan-cn.xiaomimimo.com，代码会自动补 /v1）：
# MIMO_BASE_URL=
# XIAOMI_BASE_URL=
# BYOK 加密需配置：MODSTORE_LLM_MASTER_KEY=
# 本地开发：复制为 .env.local 并设置 MODSTORE_JWT_SECRET；启动后运行：
#   python scripts/set_local_default_llm.py
#   python scripts/verify_mimo_local.py
# 工作台：钱包保存默认模型；或输入框旁「自选」选 xiaomi + mimo-v2.5-pro
# 后台编排默认（可选）：
# MODSTORE_EMPLOYEE_BENCH_PROVIDER=xiaomi
# MODSTORE_EMPLOYEE_BENCH_MODEL=mimo-v2.5-pro
#
# ════════════════════════════════════════
# 本地数据库与线上对齐（可选，PostgreSQL）
# ════════════════════════════════════════
# 默认本地开发使用 SQLite：modstore_server/modstore.db（见 MODSTORE_DB_PATH）
# 若要与服务器同一套库结构/数据，优先使用 Postgres：
#   1) docker compose up -d postgres
#   2) 复制 env.database.local.example 中的 DATABASE_URL 到 .env.local
#   3) 运行 scripts/sync_local_db_from_remote.ps1（Windows）或 sync_local_db_from_remote.sh（Linux/macOS）
#      将远程库导出再恢复到本地 Postgres（需远程只读账号或备份权限）。
# 勿同时设置 DATABASE_URL 与 MODSTORE_DB_PATH（优先 DATABASE_URL）。
# DATABASE_URL=postgresql://modstore:modstore@127.0.0.1:5432/modstore

# ════════════════════════════════════════
# 后台定时任务总开关（每日摘要、收件轮询、工作流 cron 等）
# ════════════════════════════════════════
# 多 worker / 多实例时只在「调度」专用进程置 1（如 systemd modstore-scheduler），避免重复投递。
# Docker Compose：docker-compose.yml 已为 api 固化为 0、为 scheduler 服务固化为 1；勿在 .env 里对 API 打开 1。
# MODSTORE_RUN_BACKGROUND_JOBS=0

# ════════════════════════════════════════
# 每日摘要邮件 + 回信审批部署（IMAP）
# ════════════════════════════════════════
# 摘要收件人（默认 1499383833@qq.com）；多个地址用英文逗号或分号分隔
# MODSTORE_DAILY_DIGEST_EMAIL=1499383833@qq.com
# MODSTORE_DAILY_DIGEST_ENABLED=1
# MODSTORE_DAILY_DIGEST_HOUR=8
# MODSTORE_DAILY_DIGEST_MINUTE=0
# MODSTORE_DAILY_DIGEST_TZ=Asia/Shanghai

# 摘要投递成功后，向这些用户 ID 发站内通知（需登录用户存在；与邮件并行）
# MODSTORE_DAILY_DIGEST_NOTIFY_USER_IDS=1

# 08:00 每日摘要落库后自动跑 Vibe-Coding 预备清单（更新 + 补丁 Markdown，写入同条 DailyDigestRecord）
# MODSTORE_DAILY_VIBE_PREP_ENABLED=1
# MODSTORE_DAILY_VIBE_PREP_MAX_EMPLOYEES=52
# MODSTORE_DAILY_VIBE_PREP_USER_ID=1

# Vibe 预备完成后拆分更新/补丁清单到 P-W / P-S / S-R 三产线（写入 daily_digest_records）
# MODSTORE_DAILY_VIBE_LINE_DISPATCH_ENABLED=1

# Phase A：08:15 消费 P-S 补丁清单 → dispatch_subtasks（不跑 P3–P9）
# MODSTORE_DAILY_VIBE_EXECUTE_ENABLED=1
# MODSTORE_DAILY_VIBE_EXECUTE_HOUR=8
# MODSTORE_DAILY_VIBE_EXECUTE_MINUTE=15
# MODSTORE_DAILY_VIBE_EXECUTE_PRIORITIES=P0,P1,P2
# MODSTORE_DAILY_VIBE_EXECUTE_MAX_UNITS=32
# MODSTORE_DAILY_VIBE_EXECUTE_CONCURRENCY=2

# 仓库根：摘要中 Git / pytest / 路径解析与运维 shell_exec 白名单一致（生产务必指向真实 clone）
# （若已在上方「部署档位」配置 MODSTORE_REPO_ROOT，此处无需重复）

# 每日摘要中追加「各岗位今日方案」（catalog 与值班编制 ID 交集；依赖 Tavily/DDG + GitHub API + Bench LLM）
# 生产开启全量建议：MODSTORE_DAILY_BRIEF_ENABLED=1
# MODSTORE_DAILY_BRIEF_ENABLED=0
# MODSTORE_DAILY_BRIEF_MAX=16
# 简报内 RAG / research 使用的用户 ID（默认 0）：设为真实用户 ID 后，该用户名下知识库集合会进入 visible 范围
# MODSTORE_DAILY_BRIEF_USER_ID=

# 按 pkg_id 覆盖「每日岗位方案」联网调研 brief（JSON 对象）；优先级高于员工包 manifest metadata
# MODSTORE_DAILY_BRIEF_SEEDS_JSON={"employee-interview-assistant":"AI 员工访谈与元数据补全；编制岗位问卷；runbook 字段规范；公开最佳实践"}

# 岗位简报锚定仓库 yuangon/<area>/<pkg_id>/ 真实文件（节选注入 LLM，减少泛泛而谈）；需 MODSTORE_REPO_ROOT 指向含 yuangon 的 clone
# MODSTORE_DAILY_BRIEF_GROUND_YUANGON=1
# MODSTORE_DAILY_BRIEF_GROUND_MAX_CHARS=60000  # 默认 60000；上限 200000，命中"因长度上限被截断"警告时调大
# 严格模式：三条建议带「依据」行，节选为空时禁止编造内规（默认 0）
# MODSTORE_DAILY_BRIEF_STRICT_GROUNDING=0
# 按包扩展节选 glob：键为 pkg_id 或 *，值为相对 yuangon/.../pkg 目录的 pattern 列表
# MODSTORE_DAILY_BRIEF_EXTRA_GLOBS_JSON={"*":["docs/*.md"]}

# 每日摘要邮件附带「审计计数为何为 0」说明（scheduler / DB / nginx 路径）
# MODSTORE_DIGEST_AUDIT_HINT=0

# ── TLS 证书到期巡检（每日摘要 + security.alert）参见 docs/runbooks/tls-domain-inventory.md ──
# 逗号/分号分隔的 PEM 证书路径（生产常为 nginx ssl CRT）；未配置则跳过巡检段落
# MODSTORE_TLS_CERT_PATHS=/etc/nginx/ssl/xiu-ci.com_bundle.crt
# CERT_EXPIRY_INFO_DAYS=60
# CERT_EXPIRY_WARN_DAYS=30
# CERT_EXPIRY_CRIT_DAYS=14

# 工作台 / Agent 联网检索配额（进程内存计数）
# MODSTORE_RESEARCH_DAILY_CAP=40
# MODSTORE_DIGEST_RESEARCH_CAP=64
# MODSTORE_AGENT_RESEARCH_TOOL_DAILY_CAP=80

# Agent ReAct：启用 internet_search / github_repo_snapshot 工具
# MODSTORE_AGENT_RESEARCH_TOOLS_ENABLED=0

# Agent：仅允许对白名单 host 使用 http_get（逗号分隔 hostname）
# MODSTORE_AGENT_HTTP_ALLOW_HOSTS=api.github.com,raw.githubusercontent.com

# 工作台 / 联系页联网：Bing（Playwright 填框搜索，与浏览器一致）→ Tavily（可选）→ DDG / SearXNG
# MODSTORE_BING_BROWSER=edge
# MODSTORE_BING_EDGE_HEADLESS=1
# MODSTORE_BING_EDGE_CHANNEL=msedge
# MODSTORE_WEB_CRAWL_ENGINES=bing
# 联网给 LLM：抓取搜索结果前 N 条链接页正文（默认开）
# MODSTORE_WEB_FETCH_PAGES=1
# MODSTORE_WEB_FETCH_MAX_PAGES=3
# MODSTORE_WEB_FETCH_MAX_CHARS=2500
# MODSTORE_WEB_FETCH_TIMEOUT=15
# MODSTORE_WEB_CRAWL_PER_ENGINE=5
# 仅 Bing 测试或不想走 Tavily：MODSTORE_WEB_SEARCH_USE_TAVILY=0（pytest 默认已为 0）
# MODSTORE_WEB_SEARCH_USE_TAVILY=1
# 国内或受限网络下 DuckDuckGo 常不可用，建议配置 Tavily（https://tavily.com）或自建 SearXNG 并设置下列 URL。
# MODSTORE_TAVILY_API_KEY=
# TAVILY_API_KEY=
# TVLY_API_KEY=
# TAVILY_KEY=
# MODSTORE_SEARXNG_URL=https://search.example.com
# MODSTORE_GITHUB_TOKEN=

# 定时任务 / Bench 用平台 LLM（与钱包平台密钥或以下环境变量配合）
# MODSTORE_EMPLOYEE_BENCH_PROVIDER=deepseek
# MODSTORE_EMPLOYEE_BENCH_MODEL=deepseek-chat

# 基准测试 / 同步测试：五维静态审核之后，可选再派一名「员工包质询员」对候选 manifest 跑 LLM 质询并解析 MACHINE_SCORE=0–100（写入 bench 报告 audit.pack_peer_review）
# MODSTORE_PACK_PEER_REVIEW_EMPLOYEE=employee-pack-quality-interviewer
# MODSTORE_PACK_PEER_REVIEW_MAX_MANIFEST_CHARS=14000
# MODSTORE_BENCH_PEER_REVIEW_GATE=0
# MODSTORE_BENCH_PEER_REVIEW_MIN_SCORE=55

# IMAP 收件（回信审批）：账号密码与上方 SMTP 完全一致，无需重复填写。
# 在 QQ 邮箱 → 设置 → 账户 中开启「IMAP/SMTP服务」（含 IMAP）。
# MODSTORE_INBOX_POLL_ENABLED=1
# MODSTORE_INBOX_POLL_SECONDS=120
# MODSTORE_IMAP_HOST=imap.qq.com
# MODSTORE_IMAP_PORT=993
# 仅当收件账号必须与发件不同时再设置（默认留空即使用 MODSTORE_SMTP_USER / MODSTORE_SMTP_PASSWORD）
# MODSTORE_IMAP_USER=
# MODSTORE_IMAP_PASSWORD=

# 仅接受该发件人回信中的批准令牌（与摘要中一致）；须与发摘要使用的发件/授权邮箱一致
# MODSTORE_APPROVAL_AUTHORIZED_FROM=1499383833@qq.com
# MODSTORE_APPROVAL_TOKEN_TTL_HOURS=36

# 每日 07:00 编排任务（切分支 + 跑 daily-orchestrator 员工 + 本地提交 → 待邮件审批）
# MODSTORE_DAILY_ORCHESTRATOR_ENABLED=0
# MODSTORE_DAILY_ORCHESTRATOR_HOUR=7
# MODSTORE_DAILY_ORCHESTRATOR_MINUTE=0
# MODSTORE_DAILY_ORCHESTRATOR_TZ=Asia/Shanghai
# primary：07:00 盲跑停用，改由 08:25 release_train orchestrator 消费 digest；shadow：07:00 与 08:25 并行观测
# 生产闭环建议 primary；本地调试可用 shadow
# MODSTORE_DAILY_ORCHESTRATOR_DIGEST_MODE=primary

# release_train 四段 SSOT（与营销 v10.0 并行）：每日 +0.0.0.1 · 每 10 日 installer · 每 100 日 major
# MODSTORE_RELEASE_TRAIN_ENABLED=1
# MODSTORE_RELEASE_TRAIN_JSON=/path/to/FHD/config/release_train.json
# MODSTORE_INSTALLER_PUSH_ENABLED=1
# MODSTORE_MAJOR_PUSH_ENABLED=1
# MODSTORE_INSTALLER_PUSH_ALLOW_HIGH_RISK=0
# MODSTORE_RELEASE_TRAIN_PHASE_B_ENABLED=1
# MODSTORE_RELEASE_TRAIN_PIPELINE_ENABLED=1
# MODSTORE_RELEASE_TRAIN_REQUIRE_PHASE_A=1
# MODSTORE_RELEASE_TRAIN_WAIT_PHASE_A=1
# MODSTORE_OPS_STAGED_AUTO_APPROVE=0
# MODSTORE_OPS_STAGED_AUTO_MAX_FILES=24
# 部署后 HTTP smoke（health + /market/download）；approval_dispatcher 部署后也会跑
# MODSTORE_POST_DEPLOY_SMOKE_ENABLED=1
# MODSTORE_DEPLOY_HEALTH_URL=http://127.0.0.1:9999/api/health
# MODSTORE_POST_DEPLOY_MARKET_URL=https://xiu-ci.com/market/download
# 定时 smoke（生产建议开启，配合 SLO halt）
# MODSTORE_POST_DEPLOY_SMOKE_CRON_ENABLED=0
# MODSTORE_POST_DEPLOY_SMOKE_INTERVAL_MIN=30
# smoke 失败时阻塞 orchestrator auto-merge / 低风险 auto-deploy
# MODSTORE_RELEASE_SLO_HALT=0
# MODSTORE_SLO_HALT_AUTO_MERGE=0
# MODSTORE_AUTO_PR_ENABLED=1
# 移动端合规（Android 应用商店 / APP 备案）
# 网站 ICP（xiu-ci.com 页脚）
# XCAGI_ICP_NUMBER=蜀ICP备2026014056号-3A
# APP 应用程序备案（与网站 ICP 不同号）
# XCAGI_APP_FILING_NUMBER=蜀ICP备2026014056号-3A
# XCAGI_ANDROID_APP_FILING_NUMBER=蜀ICP备2026014056号-3A
# XCAGI_ANDROID_APP_FILING_APPROVED=1
# XCAGI_LEGAL_VERSION=1
# MODSTORE_RELEASE_TRAIN_ORCHESTRATOR_HOUR=8
# MODSTORE_RELEASE_TRAIN_ORCHESTRATOR_MINUTE=25
# MODSTORE_DEPLOY_PUSH_BRANCH_PREFIX=auto/daily-
# MODSTORE_DEPLOY_PUSH_REMOTE=origin

# ════════════════════════════════════════
# 全员自治闭环（2026-05 引入）
# ════════════════════════════════════════
# 全员日常 cron 自启：扫描每位员工 manifest.employee_config_v2.schedule 并 add_job
# 默认 1（启用）；置 0 时仅手工触发
# MODSTORE_EMPLOYEE_AUTO_CRON_ENABLED=1

# 风险中间件：高风险动作（shell_exec/ssh_exec/vibe_*）必须显式 allow_high_risk_real_run；
# 设置该 token 后还需在请求中带 input_data.high_risk_gate_token 与之匹配
# MODSTORE_RISK_HIGH_GATE_TOKEN=

# CR ⇄ git 分支管线：
# - 1 (默认) 表示创建 CR 时同步落地 employees/<emp>/cr-<id> 分支（plumbing-only，不动工作树）
# - 0 关闭则退回纯 DB 模式
# MODSTORE_CR_GIT_BRANCH_ENABLED=1
# 是否在 apply CR 后顺手在当前 HEAD 提交一次（共享工作树时建议关闭）
# MODSTORE_CR_GIT_APPLY_COMMIT=0
# 是否在 apply CR 后自动 git push + gh pr create（生产开启）
# MODSTORE_CR_GIT_AUTO_PR=0
# CR 冲突合并策略：overwrite | fail_on_conflict | llm_merge
# MODSTORE_CR_MERGE_STRATEGY=overwrite

# CI 失败摘要文件（incident_collectors 周期检查；为空则跳过）
# MODSTORE_CI_FAIL_FILE=.cursor/ci-failures.txt

# 审批通过后：健康检查 URL（curl 取 HTTP 状态码，需与 expected 一致）
# MODSTORE_DEPLOY_HEALTH_URL=http://127.0.0.1:9999/api/health

# 非 Windows 跑服务时，local-sync-deploy 需显式 shell 命令（Windows 则用 scripts/sync-modstore-to-server.ps1）
# MODSTORE_SYNC_DEPLOY_BASH=bash -lc 'cd /path/to/repo/MODstore_deploy/scripts && ./your-sync.sh'

# 本地 git 提交身份（每日编排自动 commit）
# MODSTORE_GIT_AUTHOR_NAME=MODstore Bot
# MODSTORE_GIT_AUTHOR_EMAIL=bot@localhost

# 与 scripts/sync-modstore-to-server.ps1 一致（亦可依赖脚本内默认）
# DEPLOY_SSH=root@your-server
# DEPLOY_REMOTE_BASE=/root/modstore-git

# ════════════════════════════════════════
# 受控运维（shell_exec / ssh_exec 白名单，见 modstore_server/integrations/ops_action_handlers.py）
# ════════════════════════════════════════
# SSH 私钥目录：仓库根下 _local_secrets/ssh_keys（勿提交 Git）
# Nginx error 日志路径（摘要 tail 提示与 tail-nginx-error 类命令）
# OPS_NGINX_ERROR_LOG=/var/log/nginx/error.log

# ════════════════════════════════════════
# 数字管家 ↔ QQ 官方机器人 V2（modstore_server/butler_qq_bridge.py）
# ════════════════════════════════════════
# 在 https://q.qq.com/qqbot/ 创建机器人后取 AppID / AppSecret / Token，把
# Webhook 回调地址填成：https://xiu-ci.com/api/agent/butler/qq/webhook
# 仅当下面 3 个键全部配齐 + 已 pip install pynacl 时，路由才会真正注册。
# BUTLER_QQ_APP_ID=
# BUTLER_QQ_APP_SECRET=
# BUTLER_QQ_BOT_TOKEN=
# 1 = 调 sandbox.api.sgroup.qq.com，0 = 生产 api.sgroup.qq.com
# BUTLER_QQ_SANDBOX=0
#
# —— 数字管家自己的"脑子"凭证（推荐方式：AI 员工自持，不寄人篱下）——
# provider 取值见 llm_key_resolver.KNOWN_PROVIDERS（如 openai / deepseek / xiaomi / siliconflow）
# BUTLER_QQ_LLM_PROVIDER=
# BUTLER_QQ_LLM_API_KEY=
# BUTLER_QQ_LLM_MODEL=gpt-4o-mini
#
# —— 官网联系页 / 公开 corp-chat、corp-intake-fill（未单独配置时回退 BUTLER_QQ_LLM_*）——
# BUTLER_CORP_PROVIDER=openai
# BUTLER_CORP_API_KEY=
# BUTLER_CORP_MODEL=gpt-4o-mini
# BUTLER_CORP_USER_ID=
# 仅当 provider 是 OpenAI 兼容自托管端点时需要：
# BUTLER_QQ_LLM_BASE_URL=
#
# —— 兜底方式：把 QQ 来访挂在某个真人 user_id 名下，借这位用户已配的 LLM Key ——
# 仅当上面 BUTLER_QQ_LLM_* 没配时才生效
# BUTLER_QQ_BRIDGE_USER_ID=
#
# —— 一等公民 QQ 渠道：task-router-officer / employee-interview-assistant ——
# 可与管家共用同一 Webhook URL；每台机器人必须有**各自**的 AppSecret，否则
# op=13 握手里服务端无法用正确密钥签名 → QQ 后台显示未连接。
# 亦可改用 /admin/ai-accounts 建 QQ 账号（含三件套）；ENV 与账号池二选一或同时
# 填时，以本处 TASK_/EMPLOYEE_INTERVIEW_* 与 _specific_app_secret 解析为准覆盖 DB。
# TASK_ROUTER_QQ_APP_SECRET=
# TASK_ROUTER_QQ_BOT_TOKEN=
# EMPLOYEE_INTERVIEW_QQ_APP_SECRET=
# EMPLOYEE_INTERVIEW_QQ_BOT_TOKEN=

# ════════════════════════════════════════
# AI 员工产出 → CR → Git → PR → 自动合并 全闭环（断点 2/3/4/6）
# ════════════════════════════════════════
# 默认 1：员工产出有 files_changed/proposed_changes 时，落 EmployeeChangeRequest
# 并把内容暂存到分支 employees/<emp>/cr-<id>。
# MODSTORE_CR_GIT_BRANCH_ENABLED=1

# 默认 0：CR 落地时是否在主仓库做 git add+commit "apply CR-<id>"。
# 生产建议 1：让所有审批通过的 CR 都有审计提交。
# MODSTORE_CR_GIT_APPLY_COMMIT=1

# 默认 0：CR 分支建好后是否调 gh CLI 自动开 PR（带 ai-employee 标签；low risk 还会带 auto-merge）。
# 生产建议 1：与 .github/workflows/ci-auto-merge.yml 配合形成闭环。
# 需要服务器装 gh CLI，并在仓库根做 gh auth login --with-token。
# MODSTORE_CR_GIT_AUTO_PR=1
# MODSTORE_AUTO_PR_BASE_BRANCH=main
# MODSTORE_DEPLOY_PUSH_REMOTE=origin

# 默认 0：低风险 CR 是否自动审批 + 调 apply_employee_change_request 落盘。
# 生产建议 1：把"小改动文档/注释"等低风险变更的人工开销吞掉。
# MODSTORE_AUTO_APPROVE_ENABLED=1
# MODSTORE_AUTO_APPROVE_MAX_LINES=50
# 自动审批前跑窄 CI（pytest 子集 + py_compile + 可选 ruff）
# MODSTORE_AUTO_APPROVE_REQUIRE_CI=1
# MODSTORE_CR_NARROW_CI_ENABLED=1
# MODSTORE_CR_NARROW_CI_PYTEST_TIMEOUT=120
# MODSTORE_CR_NARROW_CI_RUFF=1

# 产线灰度：仅 P-S primary，其余 shadow；CR 日预算
# MODSTORE_LINE_PRIMARY_LINES=P-S
# MODSTORE_LINE_SHADOW_LINES=P-W,P-App,S-R
# MODSTORE_DAILY_CR_BUDGET_MAX=10
# MODSTORE_DAILY_CR_LINES_BUDGET=200
# MODSTORE_LINE_ROLLOUT_MIN_PASS_RATE=0.8

# 进化事实信号注入 vibe 预备
# MODSTORE_EVOLUTION_SIGNAL_LOOKBACK_HOURS=24

# Prompt 进化 A/B 自动应用
# MODSTORE_PROMPT_EVOLUTION_AB_ENABLED=1
# MODSTORE_PROMPT_EVOLUTION_AUTO_APPLY=1
# MODSTORE_PROMPT_OVERRIDE_DIR=playwright-report/prompt-overrides

# P0/P1 Cursor SDK 真执行（需 CURSOR_API_KEY 或 webhook）
# MODSTORE_CURSOR_DELEGATE_ENABLED=1
# CURSOR_API_KEY=
# MODSTORE_CURSOR_DELEGATE_WEBHOOK=
# MODSTORE_CURSOR_DELEGATE_MODEL=composer-2.5

# ════════════════════════════════════════
# 员工健康巡检 + 自动下架（断点 7）
# ════════════════════════════════════════
# 默认 1：开启巡检；扫描 EmployeeExecutionMetric，超阈值自动下架员工包并通知管理员。
# MODSTORE_HEALTH_SCAN_ENABLED=1
# MODSTORE_HEALTH_SCAN_LOOKBACK_HOURS=24
# MODSTORE_HEALTH_SCAN_WARN_THRESHOLD=3
# MODSTORE_HEALTH_SCAN_DEACTIVATE_THRESHOLD=8
# MODSTORE_HEALTH_SCAN_INTERVAL_MIN=30

# ════════════════════════════════════════
# Inbound Webhook 入口（断点 1）— 任何一个 secret 没配置该 provider 都会 503
# ════════════════════════════════════════
# GitHub: Settings → Webhooks → Add webhook → Content type=application/json →
#   Secret 与本环境变量保持一致；事件至少勾 "Push events" / "Issues" / "Pull requests"。
# MODSTORE_GITHUB_WEBHOOK_SECRET=
#
# 飞书：开放平台 → 事件订阅 → Verification Token；并在事件订阅 URL 填
#   https://xiu-ci.com/api/inbound/webhooks/feishu
# MODSTORE_FEISHU_VERIFY_TOKEN=
#
# 钉钉：自定义机器人 → 安全设置勾"加签"，把 secret 复制到这里。
# MODSTORE_DINGTALK_WEBHOOK_SECRET=
#
# 通用入口：合作方任意 JSON，请求头 Authorization: Bearer <token>。
# MODSTORE_GENERIC_WEBHOOK_TOKEN=

# ════════════════════════════════════════
# 实时 handoff 链长上限（断点 5）
# ════════════════════════════════════════
# 员工 A 在 cognition.action.handoff 给 B → B 再 handoff 给 C；最多 N 跳避免循环。
# MODSTORE_HANDOFF_MAX_DEPTH=4

# ════════════════════════════════════════
# FunASR 语音识别（工作台语音输入）
# ════════════════════════════════════════
# FunASR 需独立 Docker 部署，参见 docs/runbooks/funasr-deploy.md
# systemd API（:9999）直连宿主机 FunASR：
# FUNASR_HOST=127.0.0.1
# FUNASR_PORT=10095
# FUNASR_USE_SSL=0
# Docker Compose api 容器内访问 compose funasr 服务：
# FUNASR_HOST=funasr
# FUNASR_PORT=10095
# FUNASR_USE_SSL=0

# ════════════════════════════════════════
# 运营线打通（官网联系表单 → FHD CRM Pipeline）
# ════════════════════════════════════════
# FHD 内网基址（无尾斜杠）；本地开发一般为 http://127.0.0.1:5000
# XCAGI_FHD_INTERNAL_URL=http://127.0.0.1:5000
# XCAGI_CS_BRIDGE_MOD_ID=xcagi-customer-service-bridge
# 须与 FHD 的 XCAGI_CS_INTAKE_WEBHOOK_SECRET / LINK_SECRET 完全一致
# XCAGI_CS_INTAKE_WEBHOOK_SECRET=xcagi-cs-intake-dev-secret
# XCAGI_CS_INTAKE_LINK_SECRET=xcagi-cs-intake-dev-secret
# Webhook 失败重试队列目录
# MODSTORE_DATA_DIR=/tmp/modstore_data
# 可选：FHD operations_line_bridge 回调
# XCAGI_OPS_LINE_HOOK_SECRET=xcagi-ops-line-dev-secret

# ════════════════════════════════════════
# FunASR 语音识别（工作台语音输入）
# ════════════════════════════════════════
# FunASR 需独立 Docker 部署，参见 docs/runbooks/funasr-deploy.md
# systemd API（:9999）直连宿主机 FunASR：
# FUNASR_HOST=127.0.0.1
# FUNASR_PORT=10095
# FUNASR_USE_SSL=0
# Docker Compose api 容器内访问 compose funasr 服务：
# FUNASR_HOST=funasr
# FUNASR_PORT=10095
# FUNASR_USE_SSL=0

