.venv/
# 依赖/构建产物广覆盖（防新仓膨胀）
**/node_modules/
**/dist/
**/.vite/
**/coverage/
**/target/
*.log
.DS_Store
# 大二进制资产/构建包（不入源码仓，按需单独分发）
*.jar
*.war
*.tar.gz
*.tgz
*.zip
*.dmg
*.exe
*.apk
*.wasm
market/public/vosk/
.env
.env.local
.modstore_build.json
__pycache__/
*.py[cod]
.modstore-config.json
.modrepo-config.json
library/*
!library/.gitkeep
debug_sandbox/
web/node_modules/
web/dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
catalog_data/
modstore_server/*.db
hero-video.mp4
backups/

# 运行期产物：outbox / webhook 投递记录，生产走 /data 挂载，禁止进入源码树
modstore_server/webhook_events/
modstore_server/data/event_outbox.jsonl
modstore_server/data/event_outbox_*.jsonl
modstore_server/data/payment_orders/
modstore_server/data/chroma/
modstore_server/data/

# 运行时目录 —— 本地测试数据不得覆盖服务器生产数据
var/runtime/
var/vibe_coding/
var/employee_uploads/
modstore_server/library/

# 运行时本地密钥（AI 员工账号池、SSH 私钥等），永远不得提交
_local_secrets/

# === 密钥零泄露硬闸（新仓发布前补全；example/template 模板除外）===
.env.*
!.env.example
!.env.*.example
!.env.*.template
*.local
*.local.*
!*.local.example
*.bak
*.bak-*
*-bak-*
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
id_rsa*
id_ed25519*
*secret*
!*secret*.example
*credential*
*token*.json
*.smtp.local
.env.smtp.local
deploy-target.local.ps1

