# 片段：公网 xiu-ci.com MODstore 校验「自建机签发的」管理端身份码时，与自建 9999 实例配对使用。
# 复制到各机 .env / compose 的 environment 后，把 TOKEN 换成同一长随机串；公网机须能 TCP 访问自建 API 根。

# ---------- 自建 MODstore（119 等，签发摘要的库）----------
# MODSTORE_DIGEST_PEER_SERVICE_TOKEN=请替换为长随机串
# MODSTORE_DIGEST_PEER_ENABLE_INBOUND=1

# ---------- 公网 MODstore（xiu-ci.com）----------
# MODSTORE_DIGEST_IDENTITY_UPSTREAM_URL=http://119.27.178.147:9999
# MODSTORE_DIGEST_PEER_SERVICE_TOKEN=与自建完全相同
