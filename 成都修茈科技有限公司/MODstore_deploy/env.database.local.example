# 本地开发：让 FastAPI 使用与线上一致的 PostgreSQL（便于对齐 catalog / 用户等数据）
#
# 用法：
# 1. 在项目根执行：docker compose up -d postgres
# 2. 复制本文件片段到 .env.local（与 .env 同目录），或合并下列两行。
# 3. 执行 scripts/sync_local_db_from_remote.ps1（或 .sh）从服务器拉一份库到本机 Postgres。
# 4. 重启本地 uvicorn / npm proxy。
#
# 注意：不要同时设置 DATABASE_URL 与 MODSTORE_DB_PATH —— 代码优先使用 DATABASE_URL。
# 若此前用过 SQLite，请从 .env.local 中删除或注释 MODSTORE_DB_PATH。

DATABASE_URL=postgresql://modstore:modstore@127.0.0.1:5432/modstore

# ── 可选：与数据库片段一并写入 .env.local（生产 / Windows 本地建议显式设置）────
# 指向 monorepo 根目录；AI 员工 scope、git CR 分支、运维命令均以该路径为基准。
# Windows 示例：
# MODSTORE_REPO_ROOT=E:\成都修茈科技有限公司
# Linux/macOS 示例：
# MODSTORE_REPO_ROOT=/root/成都修茈科技有限公司
#
# 全自动审批 + PR（已默认开启，关闭则设为 0）：
MODSTORE_AUTO_APPROVE_ENABLED=1
MODSTORE_CR_GIT_APPLY_COMMIT=1
MODSTORE_CR_GIT_AUTO_PR=1
MODSTORE_DAILY_ORCHESTRATOR_ENABLED=1
MODSTORE_AUTO_PR_ENABLED=1
MODSTORE_AUTO_APPROVE_REQUIRE_CI=1
#
# 全员 manifest cron（scheduler 默认开启；关闭则 MODSTORE_EMPLOYEE_AUTO_CRON_ENABLED=0）
# MODSTORE_EMPLOYEE_AUTO_CRON_ENABLED=1
