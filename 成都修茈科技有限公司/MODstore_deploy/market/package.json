{
  "name": "modstore-market",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:corp-butler": "vite build --config vite.corp-butler.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:baseline": "vue-tsc --noEmit -p tsconfig.strict-baseline.json",
    "typecheck:strict": "vue-tsc --noEmit -p tsconfig.strict.json",
    "typecheck:ci": "node scripts/typecheck-ci.mjs",
    "test": "npm run test:unit",
    "install:native": "node scripts/install-native-bindings.mjs",
    "postinstall": "node scripts/install-native-bindings.mjs",
    "test:unit": "vitest run --config vitest.config.ts",
    "smoke:voice": "node scripts/smoke-voice-endpoint.mjs",
    "smoke:voice:pipeline": "python ../tools/smoke_voice_pipeline.py --asr-only",
    "test:watch": "vitest",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:all": "npm run typecheck && npm run test:coverage && npm run test:e2e",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,md,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,md,css}\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@huggingface/transformers": "^4.2.0",
    "@lichess-org/vosk-browser": "^0.0.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "fflate": "^0.8.2",
    "html2canvas": "^1.4.1",
    "mermaid": "^11.16.0",
    "pinia": "^3.0.4",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "overrides": {
    "protobufjs": "7.6.3",
    "dompurify": "3.4.11",
    "esbuild": "0.28.1",
    "glob": "10.5.0",
    "js-cookie": "3.0.7",
    "js-yaml": "4.2.0",
    "uuid": "11.1.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.4",
    "@vue/test-utils": "^2.4.8",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.7"
  }
}
