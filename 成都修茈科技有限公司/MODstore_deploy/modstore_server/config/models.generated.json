    "service_fee_multiplier": "1.5",
    "preauth_floor": "0.05",
    "defaults_by_modality": {
      "llm": {
        "mode": "token",
        "input_per_1k": "0.006",
        "output_per_1k": "0.018",
        "min_charge": "0.02"
      },
      "vlm": {
        "mode": "token",
        "input_per_1k": "0.006",
        "output_per_1k": "0.018",
        "min_charge": "0.02"
      },
      "embedding": {
        "mode": "token",
        "input_per_1k": "0.0005",
        "output_per_1k": "0",
        "min_charge": "0.001"
      },
      "image": {
        "mode": "per_image",
        "per_unit": "0.30",
        "unit": "image",
        "min_charge": "0.30"
      },
      "video": {
        "mode": "per_second",
        "per_unit": "0.50",
        "unit": "second",
        "min_charge": "1.00"
      },
      "ocr": {
        "mode": "per_page",
        "per_unit": "0.01",
        "unit": "page",
        "min_charge": "0.01"
      },
      "tts": {
        "mode": "per_unit",
