    "word-frequency-counter": {
      "active_version": 1,
      "created_at": "2026-05-05T11:39:14.989489+00:00",
      "domain": "统计英文文本中单词频率并返回前N个高频词",
      "name": "Word Frequency Counter",
      "skill_id": "word-frequency-counter",
      "updated_at": "2026-05-05T11:39:14.989489+00:00",
      "versions": [
        {
          "created_at": "2026-05-05T11:39:14.989489+00:00",
          "dependencies": [],
          "domain_keywords": [
            "word frequency",
            "text analysis",
            "English text",
            "top N words",
            "frequency count"
          ],
          "function_name": "count_word_frequency",
          "quality_gate": {
            "required_keys": [
              "top_words"
            ]
          },
          "signature": {
            "params": [
              "text",
              "n"
            ],
            "required_params": [
              "text",
              "n"
            ],
            "return_type": "dict"
          },
          "source_code": "import re\nfrom collections import Counter\n\ndef count_word_frequency(text: str, n: int) -> dict:\n    \"\"\"统计英文文本中单词频率并返回前N个高频词。\n\n    参数:\n        text (str): 要分析的英文文本。\n        n (int): 要返回的高频词数量。\n\n    返回:\n        dict: 包含 'top_words' 键的字典，其值为列表，每个元素是包含 'word' 和 'count' 的字典。\n              如果输入无效，返回包含 'error' 键的字典。\n    \"\"\"\n    # 验证 n 是否为正整数\n    if not isinstance(n, int) or n <= 0:\n        return {\"error\": \"n must be a positive integer\"}\n    \n    # 如果文本为空或只包含空白，返回空列表\n    if not text or not text.strip():\n        return {\"top_words\": []}\n    \n    # 将文本转换为小写并提取单词（只考虑字母序列）\n    words = re.findall(r'[a-zA-Z]+', text.lower())\n    \n    # 统计单词频率\n    word_counts = Counter(words)\n    \n    # 获取前 n 个高频词\n    top_n = word_counts.most_common(n)\n    \n    # 构建返回的列表\n    top_words_list = [{\"word\": word, \"count\": count} for word, count in top_n]\n    \n    return {\"top_words\": top_words_list}",
          "source_run_id": "vibe-15adad20",
          "test_cases": [
            {
              "assert_fn": null,
              "case_id": "happy_path",
              "expected_output": {
                "top_words": [
                  {
                    "count": 3,
                    "word": "the"
                  },
                  {
                    "count": 2,
                    "word": "fox"
                  },
                  {
                    "count": 1,
                    "word": "quick"
                  }
                ]
              },
