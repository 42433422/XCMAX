              "dict2"
            ],
            "return_type": "dict"
          },
          "source_code": "def merge_dicts_with_list(dict1, dict2) -> dict:\n    \"\"\"Merge two dictionaries, combining values into lists for conflicting keys.\n\n    Args:\n        dict1: First dictionary to merge.\n        dict2: Second dictionary to merge.\n\n    Returns:\n        A merged dictionary with values as lists for keys present in both inputs.\n        Returns a dict with 'error' key if inputs are invalid.\n    \"\"\"\n    if not isinstance(dict1, dict) or not isinstance(dict2, dict):\n        return {\"error\": \"Invalid input: both arguments must be dictionaries\"}\n    \n    result = dict1.copy()\n    for key, value in dict2.items():\n        if key in result:\n            existing = result[key]\n            if isinstance(existing, list):\n                existing.append(value)\n            else:\n                result[key] = [existing, value]\n        else:\n            result[key] = value\n    return result",
          "source_run_id": "vibe-83006867",
          "test_cases": [
            {
              "assert_fn": null,
              "case_id": "happy_path",
              "expected_output": {
