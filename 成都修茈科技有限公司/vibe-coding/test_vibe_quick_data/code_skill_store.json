            ],
            "return_type": "dict"
          },
          "source_code": "def fibonacci_with_cache(n) -> dict:\n    '''计算斐波那契数列的第n个数，支持缓存。\n\n    参数:\n        n (int): 要计算的斐波那契数列的索引。\n\n    返回:\n        dict: 包含 'n' 和 'result' 的字典；如果 n 为负数，则返回 None。\n    '''\n    if n < 0:\n        return None\n    if not hasattr(fibonacci_with_cache, 'cache'):\n        fibonacci_with_cache.cache = {}\n    cache = fibonacci_with_cache.cache\n    if n in cache:\n        result = cache[n]\n    else:\n        if n == 0:\n            result = 0\n        elif n == 1:\n            result = 1\n        else:\n            result = fibonacci_with_cache(n-1)['result'] + fibonacci_with_cache(n-2)['result']\n        cache[n] = result\n    return {'n': n, 'result': result}",
          "source_run_id": "vibe-a03ad007",
